obj_root_law_sections_1:
  sectionId (63396)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63396&sectionno=1&orderno=1&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Surrogacy`
  line `(Regulation) Act, 2021.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 25th January, 2021, vide notification No. S.O. 292(E), dated 20th January, 2021, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (63397)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63397&sectionno=2&orderno=2&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "abandoned child" means a child born out of surrogacy procedure who has been deserted`
  line `by his intending parents or guardians and declared as abandoned by the appropriate authority after`
  line `due enquiry;`
  line
  line `(b) "altruistic surrogacy" means the surrogacy in which no charges, expenses, fees,`
  line `remuneration or monetary incentive of whatever nature, except the medical expenses and such`
  line `other prescribed expenses incurred on surrogate mother and the insurance coverage for the`
  line `surrogate mother, are given to the surrogate mother or her dependents or her representative;`
  line
  line `(c) "appropriate authority" means the appropriate authority appointed under Section 35;`
  line
  line `(d) "Assisted Reproductive Technology Act" means the Assisted Reproductive Technology`
  line `(Regulation) Act, 2021;`
  line
  line `(e) "Board" means the National Assisted Reproductive Technology and Surrogacy Board`
  line `constituted under Section 17;`
  line
  line `(f) "clinical establishment" shall have the same meaning as assigned to it in the Clinical`
  line `Establishments (Registration and Regulation) Act, 2010 (23 of 2010);`
  line
  line `(g) "commercial surrogacy" means commercialisation of surrogacy services or procedures or its`
  line `component services or component procedures including selling or buying of human embryo or`
  line `trading in the sale or purchase of human embryo or gametes or selling or buying or trading the`
  line `services of surrogate motherhood by way of giving payment, reward, benefit, fees, remuneration or`
  line `monetary incentive in cash or kind, to the surrogate mother or her dependents or her representative, except the medical expenses and such other prescribed expenses incurred on the surrogate mother`
  line `and the insurance coverage for the surrogate mother;`
  line
  line `(h) "couple" means the legally married Indian man and woman above the age of 21 years and`
  line `18 years respectively;`
  line
  line `(i) "egg" includes the female gamete;`
  line
  line `(j) "embryo" means a developing or developed organism after fertilisation till the end of fiftysix days;`
  line
  line `(k) "embryologist" means a person who possesses any post-graduate medical qualification or`
  line `doctoral degree in the field of embryology or clinical embryology from a recognised university`
  line `with not less than two years of clinical experience;`
  line
  line `(l) "fertilisation" means the penetration of the ovum by the spermatozoan and fusion of genetic`
  line `materials resulting in the development of a zygote;`
  line
  line `(m) "foetus" means a human organism during the period of its development beginning on the`
  line `fifty-seventh day following fertilisation or creation (excluding any time in which its development`
  line `has been suspended) and ending at the birth;`
  line
  line `(n) "gamete" means sperm and oocyte;`
  line
  line `(o) "gynaecologist" shall have the same meaning as assigned to it in the Pre-conception and`
  line `Pre-natal Diagnostic Techniques (Prohibition of Sex Selection) Act, 1994 (57 of 1994);`
  line
  line `(p) "implantation" means the attachment and subsequent penetration by the zona-free`
  line `blastocyst, which starts five to seven days following fertilisation;`
  line
  line `(q) "insurance" means an arrangement by which a company, individual or intending couple`
  line `undertake to provide a guarantee of compensation for medical expenses, health issues, specified`
  line `loss, damage, illness or death of surrogate mother and such other prescribed expenses incurred on`
  line `such surrogate mother during the process of surrogacy;`
  line
  line `(r) "intending couple" means a couple who have a medical indication necessitating gestational`
  line `surrogacy and who intend to become parents through surrogacy;`
  line
  line `(s) "intending woman" means an Indian woman who is a widow or divorcee between the age of`
  line `35 to 45 years and who intends to avail the surrogacy;`
  line
  line `(t) "Member" means a Member of the National Assisted Reproductive Technology and`
  line `Surrogacy Board or a State Assisted Reproductive Technology and Surrogacy Board, as the case`
  line `may be;`
  line
  line `(u) "notification" means a notification published in the Official Gazette;`
  line
  line `(v) "oocyte" means naturally ovulating oocyte in the female genetic tract;`
  line
  line `(w) "Paediatrician" means a person who possesses a post-graduate qualification in paediatrics`
  line `as recognised under the Indian Medical Council Act, 1956 (102 of 1956);`
  line
  line `(x) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(y) "registered medical practitioner" means a medical practitioner who possesses any`
  line `recognised medical qualification as defined in clause (h) of Section 2 of the Indian Medical`
  line `Council Act, 1956 (102 of 1956) and whose name has been entered in a State Medical Register;`
  line
  line `(z) "regulation" means regulations made by the Board under this Act;`
  line
  line `(za) "sex selection" shall have the same meaning as assigned to it in clause (o) of Section 2 of`
  line `the Pre-conception and Pre-natal Diagnostic Techniques (Prohibition of Sex Selection) Act, 1994`
  line `(57 of 1994);`
  line
  line `(zb) "State Board" means the State Assisted Reproductive Technology and Surrogacy Board`
  line `constituted under section 26;`
  line
  line `(zc) "State Government" in relation to Union territory with Legislature, means the`
  line `Administrator of the Union territory appointed by the President under article 239 of the`
  line Constitution;
  line
  line `(zd) "surrogacy" means a practice whereby one woman bears and gives birth to a child for an`
  line `intending couple with the intention of handing over such child to the intending couple after the`
  line birth;
  line
  line `(ze) "surrogacy clinic" means surrogacy clinic, centre or laboratory, conducting assisted`
  line `reproductive technology services, invitro fertilisation services, genetic counselling centre, genetic`
  line `laboratory, Assisted Reproductive Technology Banks conducting surrogacy procedure or any`
  line `clinical establishment, by whatsoever name called, conducting surrogacy procedures in any form;`
  line
  line `(zf) "surrogacy procedures" means all gynaecological, obstetrical or medical procedures,`
  line `techniques, tests, practices or services involving handling of human gametes and human embryo in`
  line surrogacy;
  line
  line `(zg) "surrogate mother" means a woman who agrees to bear a child (who is genetically related`
  line `to the intending couple or intending woman) through surrogacy from the implantation of embryo`
  line `in her womb and fulfils the conditions as provided in sub-clause (b) of clause (iii) of Section 4;`
  line
  line `(zh) "zygote" means the fertilised oocyte prior to the first cell division.`
  line
  line `(2) Words and expressions used herein and not defined in this Act but defined in the Assisted`
  line `Reproductive Technology Act shall have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (63398)
  sectionNo (3)
  orderNo 3
  title `Prohibition and regulation of surrogacy clinics.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63398&sectionno=3&orderno=3&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_3_content:
  string
  line `On and from the date of commencement of`
  line `this Act, —`
  line
  line `(i) no surrogacy clinic, unless registered under this Act, shall conduct or associate with, or help`
  line `in any manner, in conducting activities relating to surrogacy and surrogacy procedures;`
  line
  line `(ii) no surrogacy clinic, paediatrician, gynaecologist, embryologist, registered medical`
  line `practitioner or any person shall conduct, offer, undertake, promote or associate with or avail of`
  line `commercial surrogacy in any form;`
  line
  line `(iii) no surrogacy clinic shall employ or cause to be employed or take services of any person,`
  line `whether on honorary basis or on payment, who does not possess such qualifications as may be`
  line prescribed;
  line
  line `(iv) no registered medical practitioner, gynaecologist, paediatrician, embryologist or any other`
  line `person shall conduct or cause to be conducted or aid in conducting by himself or through any other`
  line `person surrogacy or surrogacy procedures at a place other than a place registered under this Act;`
  line
  line `(v) no surrogacy clinic, registered medical practitioner, gynaecologist, paediatrician,`
  line `embryologist or any other person shall promote, publish, canvass, propagate or advertise or cause`
  line `to be promoted, published, canvassed, propagated or advertised which—`
  line
  line `(a) is aimed at inducing or is likely to induce a woman to act as a surrogate mother;`
  line
  line `(b) is aimed at promoting a surrogacy clinic for commercial surrogacy or promoting`
  line `commercial surrogacy in general;`
  line
  line `(c) seeks or aimed at seeking a woman to act as a surrogate mother;`
  line
  line `(d) states or implies that a woman is willing to become a surrogate mother; or`
  line
  line `(e) advertises commercial surrogacy in print or electronic media or in any other form;`
  line
  line `(vi) no surrogacy clinic, registered medical practitioner, gynaecologist, paediatrician,`
  line `embryologist, intending couple or any other person shall conduct or cause abortion during the`
  line `period of surrogacy without the written consent of the surrogate mother and on authorisation of the`
  line `same by the appropriate authority concerned:`
  line
  line `Provided that the authorisation of the appropriate authority shall be subject to, and in`
  line `compliance with, the provisions of the Medical Termination of Pregnancy Act, 1971 (34 of 1971);`
  line
  line `(vii) no surrogacy clinic, registered medical practitioner, gynaecologist, paediatrician,`
  line `embryologist, intending couple or any other person shall store a human embryo or gamete for the`
  line `purpose of surrogacy:`
  line
  line `Provided that nothing contained in this clause shall affect such storage for other legal purposes`
  line `like sperm banks, IVF and medical research for such period and in such manner as may be`
  line prescribed;
  line
  line `(viii) no surrogacy clinic, registered medical practitioner, gynaecologist, paediatrician,`
  line `embryologist, intending couple or any other person shall in any form conduct or cause to be`
  line `conducted sex selection for surrogacy.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (63399)
  sectionNo (4)
  orderNo 4
  title `Regulation of surrogacy and surrogacy procedures.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63399&sectionno=4&orderno=4&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_4_content:
  string
  line `On and from the date of`
  line `commencement of this Act,---`
  line
  line `(i) no place including a surrogacy clinic shall be used or cause to be used by any person for`
  line `conducting surrogacy or surrogacy procedures, except for the purposes specified in clause (ii) and`
  line `after satisfying all the conditions specified in clause (iii);`
  line
  line `(ii) no surrogacy or surrogacy procedures shall be conducted, undertaken, performed or availed`
  line `of, except for the following purposes, namely:`
  line
  line `(a) when an intending couple has a medical indication necessitating gestational surrogacy:`
  line
  line `Provided that a couple of Indian origin or an intending woman who intends to avail`
  line `surrogacy, shall obtain a certificate of recommendation from the Board on an application made`
  line `by the said persons in such form and manner as may be prescribed.`
  line
  line `Explanation.---For the purposes of this sub-clause and item (I) of sub-clause (a) of clause`
  line `(iii) the expression "gestational surrogacy" means a practice whereby a surrogate mother carries`
  line `a child for the intending couple through implantation of embryo in her womb and the child is`
  line `not genetically related to the surrogate mother;`
  line
  line `(b) when it is only for altruistic surrogacy purposes;`
  line
  line `(c) when it is not for commercial purposes or for commercialisation of surrogacy or`
  line `surrogacy procedures;`
  line
  line `(d) when it is not for producing children for sale, prostitution or any other form of`
  line `exploitation; and`
  line
  line `(e) any other condition or disease as may be specified by regulations made by the Board;`
  line
  line `(iii) no surrogacy or surrogacy procedures shall be conducted, undertaken, performed or`
  line `initiated, unless the Director or in-charge of the surrogacy clinic and the person qualified to do so`
  line `are satisfied, for reasons to be recorded in writing, that the following conditions have been`
  line `fulfilled, namely:---`
  line
  line `(a) the intending couple is in possession of a certificate of essentiality issued by the`
  line `appropriate authority, after satisfying itself, for the reasons to be recorded in writing, about the`
  line `fulfilment of the following conditions, namely:---`
  line
  line `(I) a certificate of a medical indication in favour of either or both members of the`
  line `intending couple or intending woman necessitating gestational surrogacy from a District`
  line `Medical Board.`
  line
  line `Explanation.---For the purposes of this item, the expression "District Medical Board"`
  line `means a medical board under the Chairpersonship of Chief Medical Officer or Chief Civil`
  line `Surgeon or Joint Director of Health Services of the district and comprising of at least two`
  line `other specialists, namely, the chief gynaecologist or obstetrician and chief paediatrician of`
  line `the district;`
  line
  line `(II) an order concerning the parentage and custody of the child to be born through`
  line `surrogacy, has been passed by a court of the Magistrate of the first class or above on an`
  line `application made by the intending couple or the intending woman and the surrogate mother,`
  line `which shall be the birth affidavit after the surrogate child is born; and`
  line
  line `(III) an insurance coverage of such amount and in such manner as may be prescribed in`
  line `favour of the surrogate mother for a period of thirty-six months covering postpartum`
  line `delivery complications from an insurance company or an agent recognised by the Insurance`
  line `Regulatory and Development Authority established under the Insurance Regulatory and`
  line `Development Authority Act, 1999 (41 of 1999);`
  line
  line `(b) the surrogate mother is in possession of an eligibility certificate issued by the appropriate`
  line `authority on fulfilment of the following conditions, namely:---`
  line
  line `(I) no woman, other than an ever married woman having a child of her own and between`
  line `the age of 25 to 35 years on the day of implantation, shall be a surrogate mother or help in`
  line `surrogacy by donating her egg or oocyte or otherwise;`
  line
  line `(II) a willing woman shall act as a surrogate mother and be permitted to undergo`
  line `surrogacy procedures as per the provisions of this Act:`
  line
  line `Provided that the intending couple or the intending woman shall approach the`
  line `appropriate authority with a willing woman who agrees to act as a surrogate mother;`
  line
  line `(III) no woman shall act as a surrogate mother by providing her own gametes;`
  line
  line `(IV) no woman shall act as a surrogate mother more than once in her lifetime:`
  line
  line `Provided that the number of attempts for surrogacy procedures on the surrogate mother`
  line `shall be such as may be prescribed; and`
  line
  line `(V) a certificate of medical and psychological fitness for surrogacy and surrogacy`
  line `procedures from a registered medical practitioner;`
  line
  line `(c) an eligibility certificate for intending couple is issued separately by the appropriate`
  line `authority on fulfilment of the following conditions, namely:---`
  line
  line `(I) the intending couple are married and between the age of 23 to 50 years in case of`
  line `female and between 26 to 55 years in case of male on the day of certification;`
  line
  line `(II) the intending couple have not had any surviving child biologically or through`
  line `adoption or through surrogacy earlier:`
  line
  line `Provided that nothing contained in this item shall affect the intending couple who have a`
  line `child and who is mentally or physically challenged or suffers from life threatening disorder`
  line `or fatal illness with no permanent cure and approved by the appropriate authority with due`
  line `medical certificate from a District Medical Board; and`
  line
  line `(III) such other conditions as may be specified by the regulations.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (63400)
  sectionNo (5)
  orderNo 5
  title `Prohibition of conducting surrogacy.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63400&sectionno=5&orderno=5&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_5_content:
  string
  line `No person including a relative or husband of a`
  line `surrogate mother or intending couple or intending woman shall seek or encourage to conduct any`
  line `surrogacy or surrogacy procedures on her except for the purpose specified in clause (ii) of section 4`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (63401)
  sectionNo (6)
  orderNo 6
  title `Written informed consent of surrogate mother.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63401&sectionno=6&orderno=6&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_6_content:
  string
  line `(1) No person shall seek or conduct`
  line `surrogacy procedures unless he has—`
  line
  line `(i) explained all known side effects and after effects of such procedures to the surrogate mother`
  line `concerned; and`
  line
  line `(ii) obtained in the prescribed form, the written informed consent of the surrogate mother to`
  line `undergo such procedures in the language she understands.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the surrogate mother shall have an`
  line `option to withdraw her consent for surrogacy before the implantation of human embryo in her womb.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (63402)
  sectionNo (7)
  orderNo 7
  title `Prohibition to abandon child born through surrogacy.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63402&sectionno=7&orderno=7&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_7_content:
  string
  line `The intending couple or intending`
  line `woman shall not abandon the child, born out of a surrogacy procedure, whether within India or`
  line `outside, for any reason whatsoever, including but not restricted to, any genetic defect, birth defect,`
  line `any other medical condition, the defects developing subsequently, sex of the child or conception of`
  line `more than one baby and the like.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (63403)
  sectionNo (8)
  orderNo 8
  title `Rights of surrogate child.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63403&sectionno=8&orderno=8&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_8_content:
  string
  line `A child born out of surrogacy procedure, shall be deemed to be a`
  line `biological child of the intending couple or intending woman and the said child shall be entitled to all`
  line `the rights and privileges available to a natural child under any law for time being in force.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (63404)
  sectionNo (9)
  orderNo 9
  title `Number of oocytes or human embryos to be implanted.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63404&sectionno=9&orderno=9&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_9_content:
  string
  line `The number of oocytes or human`
  line `embryos to be implanted in the uterus of the surrogate mother for the purpose of surrogacy, shall be`
  line `such as may be prescribed.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (63405)
  sectionNo (10)
  orderNo 10
  title `Prohibition of abortion.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63405&sectionno=10&orderno=10&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_10_content:
  string
  line `No person, organisation, surrogacy clinic, laboratory or clinical`
  line `establishment of any kind shall force the surrogate mother to abort at any stage of surrogacy except in`
  line `such conditions as may be prescribed.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (63406)
  sectionNo (11)
  orderNo 11
  title `Registration of surrogacy clinics.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63406&sectionno=11&orderno=11&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_11_content:
  string
  line `(1) No person shall establish any surrogacy clinic for`
  line `undertaking surrogacy or to render surrogacy procedures in any form unless such clinic is duly`
  line `registered under this Act.`
  line
  line `(2) Every application for registration under sub-section (1) shall be made to the appropriate`
  line `authority in such form, manner and shall be accompanied by such fees as may be prescribed.`
  line
  line `(3) Every surrogacy clinic which is conducting surrogacy or surrogacy procedures, partly or`
  line `exclusively, referred to in clause (ii) of section 4 shall, within a period of sixty days from the date of`
  line `appointment of appropriate authority, apply for registration:`
  line
  line `Provided that such clinic shall cease to conduct any such counselling or procedures on the expiry`
  line `of six months from the date of commencement of this Act, unless such clinic has applied for`
  line `registration and is so registered separately or till such application is disposed of, whichever is earlier.`
  line
  line `(4) No surrogacy clinic shall be registered under this Act, unless the appropriate authority is`
  line `satisfied that such clinic is in a position to provide such facilities and maintain such equipment and`
  line `standards including specialised manpower, physical infrastructure and diagnostic facilities as may be`
  line prescribed.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (63407)
  sectionNo (12)
  orderNo 12
  title `Certificate of registration.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63407&sectionno=12&orderno=12&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_12_content:
  string
  line `(1) The appropriate authority shall after holding an enquiry and`
  line `after satisfying itself that the applicant has complied with all the requirements of this Act and the rules`
  line `and regulations made thereunder, grant a certificate of registration to the surrogacy clinic, within a`
  line `period of ninety days from the date of application received by it, in such form, on payment of such`
  line `fees and in such manner, as may be prescribed.`
  line
  line `(2) Where, after the inquiry and after giving an opportunity of being heard to the applicant, the`
  line `appropriate authority is satisfied that the applicant has not complied with the requirements of this Act`
  line `or the rules or regulations made thereunder, it shall, for reasons to be recorded in writing, reject the`
  line `application for registration.`
  line
  line `(3) Every certificate of registration shall be valid for a period of three years and shall be renewed`
  line `in such manner and on payment of such fees as may be prescribed.`
  line
  line `(4) The certificate of registration shall be displayed by the surrogacy clinic at a conspicuous place.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (63408)
  sectionNo (13)
  orderNo 13
  title `Cancellation or suspension of registration .`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63408&sectionno=13&orderno=13&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_13_content:
  string
  line `(1) The appropriate authority may, suo motu or`
  line `on receipt of a complaint, issue a notice to the surrogacy clinic to show cause as to why its registration`
  line `should not be suspended or cancelled for the reasons mentioned in the notice.`
  line
  line `(2) If after giving a reasonable opportunity of being heard to the surrogacy clinic, the appropriate`
  line `authority is satisfied that there has been a breach of the provisions of the Act or the rules or`
  line `regulations made thereunder, it may, without prejudice to any criminal action that it may take against`
  line `such clinic, suspend its registration for such period as it may think fit or cancel its registration, as the`
  line `case may be.`
  line
  line `(3) Notwithstanding anything contained in sub-sections (1) and (2), if the appropriate authority is`
  line `of the opinion that it is necessary or expedient to do so in the public interest, it may, for reasons to be`
  line `recorded in writing, suspend the registration of any surrogacy clinic without issuing any notice under`
  line `sub-section (1).`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (63409)
  sectionNo (14)
  orderNo 14
  title Appeal.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63409&sectionno=14&orderno=14&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_14_content:
  string
  line `The surrogacy clinic or the intending couple or the intending woman may, within a`
  line `period of thirty days from the date of receipt of the communication relating to order of rejection of`
  line `application, suspension or cancellation of registration passed by the appropriate authority under`
  line `section 13 and communication relating to rejection of the certificates under section 4, prefer an appeal`
  line `against such order to—`
  line
  line `(a) the State Government, where the appeal is against the order of the appropriate authority of a`
  line State;
  line
  line `(b) the Central Government, where the appeal is against the order of the appropriate authority`
  line `of a Union territory,`
  line
  line `in such manner as may be prescribed.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (63410)
  sectionNo (15)
  orderNo 15
  title `Establishment of National Assisted Reproductive Technology and Surrogacy Registry.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63410&sectionno=15&orderno=15&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_15_content:
  string
  line `There shall be established a Registry to be called the National Assisted Reproductive Technology and`
  line `Surrogacy Registry for the purposes of registration of surrogacy clinics under this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (63450)
  sectionNo (16)
  orderNo 16
  title `Application of provisions of Assisted Reproductive Technology Act with respect to National Registry.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63450&sectionno=16&orderno=16&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_16_content:
  string
  line `The National Assisted Reproductive Technology and Surrogacy Registry`
  line `referred to in section 15 and to be established under section 9 of the Assisted Reproductive`
  line `Technology Act shall be the National Registry for the purposes of this Act and the functions to be`
  line `discharged by the said Registry under the Assisted Reproductive Technology Act shall, mutatis`
  line `mutandis, apply.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (63412)
  sectionNo (17)
  orderNo 17
  title `Constitution of National Assisted Reproductive Technology and Surrogacy Board.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63412&sectionno=17&orderno=17&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_17_content:
  string
  line `(1) The Central Government shall, by notification, constitute a Board to be known as the National`
  line `Assisted Reproductive Technology and Surrogacy Board to exercise the powers and perform the`
  line `functions conferred on the Board under this Act.`
  line
  line `(2) The Board shall consist of---`
  line
  line `(a) the Minister in-charge of the Ministry of Health and Family Welfare, the Chairperson,`
  line `ex officio;`
  line
  line `(b) the Secretary to the Government of India in-charge of the Department dealing with the`
  line `surrogacy matter, Vice-Chairperson, ex officio;`
  line
  line `(c) three women Members of Parliament, of whom two shall be elected by the House of the`
  line `People and one by the Council of States, Members, ex officio;`
  line
  line `(d) three Members of the Ministries of the Central Government in-charge of Women and Child`
  line `Development, Legislative Department in the Ministry of Law and Justice and the Ministry of`
  line `Home Affairs, not below the rank of Joint Secretary, Members,ex officio;`
  line
  line `(e) the Director General of Health Services of the Central Government, Member, ex officio;`
  line
  line `(f) ten expert Members to be appointed by the Central Government in such manner as may be`
  line `prescribed and two each from amongst---`
  line
  line `(i) eminent medical geneticists or embryologists;`
  line
  line `(ii) eminent gynaecologists and obstetricians;`
  line
  line `(iii) eminent social scientists;`
  line
  line `(iv) representatives of women welfare organisations; and`
  line
  line `(v) representatives from civil society working on women's health and child issues,`
  line
  line `possessing such qualifications and experience as may be prescribed;`
  line
  line `(g) four Chairpersons of the State Boards to be nominated by the Central Government by`
  line `rotation to represent the States and the Union territories, two in the alphabetical order and two in`
  line `the reverse alphabetical order, Member, ex officio; and`
  line
  line `(h) an officer, not below the rank of a Joint Secretary to the Central Government, in-charge of`
  line `Surrogacy Division in the Ministry of Health and Family Welfare, who shall be the Member-Secretary, ex officio.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (63413)
  sectionNo (18)
  orderNo 18
  title `Term of office of Members.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63413&sectionno=18&orderno=18&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_18_content:
  string
  line `(1) The term of office of a Member, other than an ex officio`
  line `Member, shall be---`
  line
  line `(a) in case of election under clause (c) of sub-section (2) of section 17, three years:`
  line
  line `Provided that the term of such Member shall come to an end as soon as the Member becomes a`
  line `Minister or Minister of State or Deputy Minister, or the Speaker or the Deputy Speaker of the`
  line `House of the People, or the Deputy Chairman of the Council of States or ceases to be a Member of`
  line `the House from which she was elected; and`
  line
  line `(b) in case of appointment under clause (f) of sub-section (2) of section 17, three years:`
  line
  line `Provided that the person to be appointed as Member under this clause shall be of such age as`
  line `may be prescribed.`
  line
  line `(2) Any vacancy occurring in the office whether by reason of his death, resignation or inability to`
  line `discharge his functions owing to illness or other incapacity, shall be filled by the Central Government`
  line `by making a fresh appointment within a period of one month from the date on which such vacancy`
  line `occurs and the Member so appointed shall hold office for the remainder of the term of office of the`
  line `person in whose place he is so appointed.`
  line
  line `(3) The Vice-Chairperson shall perform such functions as may be assigned to him by the`
  line `Chairperson from time to time.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (63414)
  sectionNo (19)
  orderNo 19
  title `Meetings of Board.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63414&sectionno=19&orderno=19&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_19_content:
  string
  line `(1) The Board shall meet at such places and times and shall observe`
  line `such rules of procedure in regard to the transaction of business at its meetings (including the quorum`
  line `at its meetings) as may be determined by the regulations:`
  line
  line `Provided that the Board shall meet at least once in six months.`
  line
  line `(2) The Chairperson shall preside at the meeting of the Board and if for any reason the Chairperson`
  line `is unable to attend the meeting of the Board, the Vice-Chairperson shall preside at the meetings of the`
  line Board.
  line
  line `(3) All questions which come up before any meeting of the Board shall be decided by a majority of`
  line `the votes of the members present and voting, and in the event of an equality of votes, the Chairperson,`
  line `or in his absence, the Vice-Chairperson shall have a second or casting vote.`
  line
  line `(4) The Members, other than ex officio Members, shall receive only compensatory travelling`
  line `expenses for attending the meetings of the Board.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (63415)
  sectionNo (20)
  orderNo 20
  title `Vacancies, etc., not to invalidate proceedings of Board.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63415&sectionno=20&orderno=20&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_20_content:
  string
  line `No act or proceeding of the Board`
  line `shall be invalid merely by reason of—`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Board; or`
  line
  line `(b) any defect in the appointment of a person acting as a Member of the Board; or`
  line
  line `(c) any irregularity in the procedure of the Board not affecting the merits of the case.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (63416)
  sectionNo (21)
  orderNo 21
  title `Disqualifications for appointment as Member.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63416&sectionno=21&orderno=21&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_21_content:
  string
  line `(1) A person shall be disqualified for`
  line `being appointed and continued as a Member if, he—`
  line
  line `(a) has been adjudged as an insolvent; or`
  line
  line `(b) has been convicted of an offence, which in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as a Member; or`
  line
  line `(d) has acquired such financial or other interest, as is likely to affect prejudicially his functions`
  line `as a Member; or`
  line
  line `(e) has so abused his position, as to render his continuance in office prejudicial to the public`
  line `interest; or`
  line
  line `(f) is a practicing member or an office-bearer of any association representing surrogacy clinics,`
  line `having financial or other interest likely to affect prejudicially, his function as a Member; or`
  line
  line `(g) is an office-bearer, heading or representing, any of the professional bodies having`
  line `commercial interest in surrogacy or infertility.`
  line
  line `(2) The Members referred to in clause (f) of section 17 shall not be removed from their office`
  line `except by an order of the Central Government on the ground of their proved misbehaviour or`
  line `incapacity after the Central Government, has, on an inquiry, held in accordance with the procedure`
  line `prescribed in this behalf by the Central Government, come to the conclusion that the Member ought`
  line `on any such ground to be removed.`
  line
  line `(3) The Central Government may suspend any Member against whom an inquiry under sub-section`
  line `(2) is being initiated or pending until the Central Government has passed an order on receipt of the`
  line `report of the inquiry.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (63417)
  sectionNo (22)
  orderNo 22
  title `Temporary association of persons with Board for particular purposes.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63417&sectionno=22&orderno=22&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_22_content:
  string
  line `(1) The Board`
  line `may associate with itself, in such manner and for such purposes as may be determined by the`
  line `regulations, any person whose assistance or advice it may desire in carrying out any of the provisions`
  line `of this Act.`
  line
  line `(2) A person associated with the Board under sub-section (1) shall have a right to take part in the`
  line `discussions relevant to that purpose, but shall not have a right to vote at a meeting of the Board and`
  line `shall not be a Member for any other purpose.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (63418)
  sectionNo (23)
  orderNo 23
  title `Authentication of orders and other instruments of Board.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63418&sectionno=23&orderno=23&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_23_content:
  string
  line `All orders and decisions of the`
  line `Board shall be authenticated by the signature of the Chairperson and all other instruments issued by`
  line `the Board shall be authenticated by the signature of the Member-Secretary of the Board.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (63419)
  sectionNo (24)
  orderNo 24
  title `Eligibility of Member for re-appointment.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63419&sectionno=24&orderno=24&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_24_content:
  string
  line `Subject to other terms and conditions of`
  line `service as may be prescribed, any person ceasing to be a Member shall be eligible for re-appointment`
  line `as such Member:`
  line
  line `Provided that no Member other than an ex officio Member shall be appointed for more than two`
  line `consecutive terms.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (63420)
  sectionNo (25)
  orderNo 25
  title `Functions of Board.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63420&sectionno=25&orderno=25&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_25_content:
  string
  line `The Board shall discharge the following`
  line `functions, namely: —`
  line
  line `(a) to advise the Central Government`
  line `on policy matters relating to surrogacy;`
  line
  line `(b) to review and monitor the implementation of the Act, and the rules and regulations made`
  line `thereunder and recommend to the Central Government, changes therein;`
  line
  line `(c) to lay down the code of conduct to be observed by persons working at surrogacy clinics;`
  line
  line `(d) to set the minimum standards of physical infrastructure, laboratory and diagnostic`
  line `equipment and expert manpower to be employed by the surrogacy clinics;`
  line
  line `(e) to oversee the performance of various bodies constituted under the Act and take appropriate`
  line `steps to ensure their effective performance;`
  line
  line `(f) to supervise the functioning of State Assisted Reproductive Technology and Surrogacy`
  line `Boards; and`
  line
  line `(g) such other functions as may be prescribed.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (63421)
  sectionNo (26)
  orderNo 26
  title `Constitution of State Assisted Reproductive Technology and Surrogacy Board.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63421&sectionno=26&orderno=26&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_26_content:
  string
  line Each
  line `State and Union territory having Legislature shall constitute a Board to be known as the State Assisted`
  line `Reproductive Technology and Surrogacy Board or the Union territory Assisted Reproductive`
  line `Technology and Surrogacy Board, as the case may be, which shall discharge the following functions,`
  line `namely:—`
  line
  line `(i) to review the activities of the appropriate authorities functioning in the State or Union`
  line `territory and recommend appropriate action against them;`
  line
  line `(ii) to monitor the implementation of the provisions of the Act, and the rules and regulations`
  line `made thereunder and make suitable recommendations relating thereto, to the Board;`
  line
  line `(iii) to send such consolidated reports as may be prescribed, in respect of the various activities`
  line `undertaken in the State under the Act, to the Board and the Central Government; and`
  line
  line `(iv) such other functions as may be prescribed.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (63422)
  sectionNo (27)
  orderNo 27
  title `Composition of State Board.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63422&sectionno=27&orderno=27&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_27_content:
  string
  line `The State Board shall consist of.---`
  line
  line `(a) the Minister in-charge of Health and Family Welfare in the State, Chairperson, ex officio;`
  line
  line `(b) the Secretary in-charge of the Department of Health and Family Welfare, Vice-Chairperson,`
  line `ex officio;`
  line
  line `(c) Secretaries or Commissioners in-charge of the Departments of Women and Child`
  line `Development, Social Welfare, Law and Justice and Home Affairs or their nominees, members, ex`
  line officio;
  line
  line `(d) Director-General of Health and Family Welfare of the State Government, member, ex`
  line officio;
  line
  line `(e) three women members of the State Legislative Assembly or Union territory Legislative`
  line `Council, members, ex officio;`
  line
  line `(f) ten expert members to be appointed by the State Government in such manner as may be`
  line `prescribed, two each from amongst---`
  line
  line `(i) eminent medical geneticists or embryologists;`
  line
  line `(ii) eminent gynaecologists and obstetricians;`
  line
  line `(iii) eminent social scientists;`
  line
  line `(iv) representatives of women welfare organisations; and`
  line
  line `(v) representatives from civil society working on women's health and child issues,`
  line
  line `possessing such qualifications and experiences as may be prescribed;`
  line
  line `(g) an officer not below the rank of Joint Secretary to the State Government in-charge of`
  line `Family Welfare, who shall be the Member-Secretary, ex officio`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (63423)
  sectionNo (28)
  orderNo 28
  title `Term of office of members.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63423&sectionno=28&orderno=28&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_28_content:
  string
  line `(1) The term of office of a member, other than an ex officio`
  line `member, shall be---.`
  line
  line `(a) in case of nomination under clause (e) of section 27, three years:`
  line
  line `Provided that the term of such member shall come to an end as soon as the member becomes a`
  line `Minister or Minister of State or Deputy Minister, or the Speaker or the Deputy Speaker of the`
  line `Legislative Assembly, or the Deputy Chairman of the Legislative Council or ceases to be a`
  line `member of the House from which she was elected; and`
  line
  line `(b) in case of appointment under clause (f) of section 27, three years:`
  line
  line `Provided that the person to be appointed as member under this clause shall be of such age, as`
  line `may be prescribed.`
  line
  line `(2) Any vacancy occurring in the office whether by reason of his death, resignation or inability to`
  line `discharge his functions owing to illness or other incapacity, shall be filled within a period of one`
  line `month from the date on which such vacancy occurs by the State Government by making a fresh`
  line `appointment and the member so appointed shall hold office for the remainder of the term of office of`
  line `the person in whose place he is so appointed.`
  line
  line `(3) The Vice-Chairperson shall perform such functions as may be assigned to him by the`
  line `Chairperson from time to time.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (63424)
  sectionNo (29)
  orderNo 29
  title `Meetings of State Board.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63424&sectionno=29&orderno=29&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_29_content:
  string
  line `(1) The State Board shall meet at such places and times and shall`
  line `observe such rules of procedure in regard to the transaction of business at its meetings (including the`
  line `quorum at its meetings) as may be specified by the regulations:`
  line
  line `Provided that the State Board shall meet at least once in four months.`
  line
  line `(2) The Chairperson shall preside at the meetings of the Board and if for any reason the Chairman`
  line `is unable to attend the meeting of the State Board, the Vice-Chairperson shall preside at the meetings`
  line `of the State Board.`
  line
  line `(3) All questions which come up before any meeting of the State Board shall be decided by a`
  line `majority of the votes of the members present and voting, and in the event of an equality of votes, the`
  line `Chairperson, or in his absence, the Vice-Chairperson shall have a second or casting vote.`
  line
  line `(4) The members, other than ex officio members, shall receive only compensatory travelling`
  line `expenses for attending the meetings of the State Board.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (63425)
  sectionNo (30)
  orderNo 30
  title `Vacancies, etc., not to invalidate proceedings of State Board.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63425&sectionno=30&orderno=30&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_30_content:
  string
  line `No act or proceeding of the`
  line `State Board shall be invalid merely by reason of—`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the State Board; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the State Board; or`
  line
  line `(c) any irregularity in the procedure of the State Board not affecting the merits of the case.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (63426)
  sectionNo (31)
  orderNo 31
  title `Disqualifications for appointment as member.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63426&sectionno=31&orderno=31&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_31_content:
  string
  line `(1) A person shall be disqualified for being`
  line `appointed and continued as a member if, he`
  line
  line `(a) has been adjudged as an insolvent; or`
  line
  line `(b) has been convicted of an offence, which in the opinion of the State Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as a member; or`
  line
  line `(d) has acquired such financial or other interest, as is likely to affect prejudicially his functions`
  line `as a member; or`
  line
  line `(e) has so abused his position, as to render his continuance in office prejudicial to the public`
  line `interest; or`
  line
  line `(f) is a practicing member or an office-bearer of any association representing surrogacy clinics,`
  line `having financial or other interest likely to affect prejudicially, his functions as a member; or`
  line
  line `(g) is an office-bearer, heading or representing, any of the professional bodies having`
  line `commercial interest in surrogacy or infertility.`
  line
  line `(2) The members referred to in clause (f) of section 27 shall not be removed from their office`
  line `except by an order of the State Government on the ground of their proved misbehaviour or incapacity`
  line `after the State Government, has, on an inquiry, held in accordance with the procedure prescribed in`
  line `this behalf by the State Government, come to the conclusion that the member ought on any such`
  line `ground to be removed.`
  line
  line `(3) The State Government may suspend any member against whom an inquiry under sub-section`
  line `(2) is being initiated or pending until the State Government has passed an order on receipt of the`
  line `report of the inquiry.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (63427)
  sectionNo (32)
  orderNo 32
  title `Temporary association of persons with State Board for particular purposes.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63427&sectionno=32&orderno=32&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_32_content:
  string
  line `(1) The`
  line `State Board may associate with itself, in such manner and for such purposes as may be determined by`
  line `the regulations, any person whose assistance or advice it may desire in carrying out any of the`
  line `provisions of this Act.`
  line
  line `(2) A person associated with it by the State Board under sub-section (1) shall have a right to take`
  line `part in the discussions relevant to that purpose, but shall not have a right to vote at a meeting of the`
  line `State Board and shall not be a member for any other purpose.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (63428)
  sectionNo (33)
  orderNo 33
  title `Authentication of orders and other instruments of State Board.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63428&sectionno=33&orderno=33&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_33_content:
  string
  line `All orders and decisions`
  line `of the State Board shall be authenticated by the signature of the Chairperson and all other instruments`
  line `issued by the State Board shall be authenticated by the signature of the Member-Secretary of the State`
  line Board.
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (63429)
  sectionNo (34)
  orderNo 34
  title `Eligibility of member for re-appointment.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63429&sectionno=34&orderno=34&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_34_content:
  string
  line `Subject to the other terms and conditions of`
  line `service as may be prescribed, any person ceasing to be a member shall be eligible for re-appointment`
  line `as such member:`
  line
  line `Provided that no member other than an ex officio member shall be appointed for more than two`
  line `consecutive terms.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (63430)
  sectionNo (35)
  orderNo 35
  title `Appointment of appropriate authority.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63430&sectionno=35&orderno=35&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_35_content:
  string
  line `(1) The Central Government shall, within a period`
  line `of ninety days from the date of commencement of this Act, by notification, appoint one or more`
  line `appropriate authorities for each of the Union territories for the purposes of this Act and the Assisted`
  line `Reproductive Technology Act.`
  line
  line `(2) The State Government shall, within a period of ninety days from the date of commencement of`
  line `this Act, by notification, appoint one or more appropriate authorities for the whole or any part of the`
  line `State for the purposes of this Act and the Assisted Reproductive Technology Act.`
  line
  line `(3) The appropriate authority, under sub-section (1) or sub-section (2), shall,---`
  line
  line `(a) when appointed for the whole of the State or the Union territory, consist of---`
  line
  line `(i) an officer of or above the rank of the Joint Secretary of the Health and Family Welfare`
  line `Department--Chairperson, ex officio;`
  line
  line `(ii) an officer of or above the rank of the Joint Director of the Health and Family Welfare`
  line `Department--Vice Chairperson, ex officio;`
  line
  line `(iii) an eminent woman representing women's organisation--member;`
  line
  line `(iv) an officer of Law Department of the State or the Union territory concerned not below`
  line `the rank of a Deputy Secretary-member; and`
  line
  line `(v) an eminent registered medical practitioner--member:`
  line
  line `Provided that any vacancy occurring therein shall be filled within one month of the`
  line `occurrence of such vacancy;`
  line
  line `(b) when appointed for any part of the State or the Union territory, be officers of such other`
  line `rank as the State Government or the Central Government, as the case may be, may deem fit.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (63431)
  sectionNo (36)
  orderNo 36
  title `Functions of appropriate authority.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63431&sectionno=36&orderno=36&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_36_content:
  string
  line `The appropriate authority shall discharge the`
  line `following functions, namely:---`
  line
  line `(a) to grant, suspend or cancel registration of a surrogacy clinic;`
  line
  line `(b) to enforce the standards to be fulfilled by the surrogacy clinics;`
  line
  line `(c) to investigate complaints of breach of the provisions of this Act, rules and regulations made`
  line `thereunder and take legal action as per provision of this Act;`
  line
  line `(d) to take appropriate legal action against the use of surrogacy by any person at any place other`
  line `than prescribed, suo motu or brought to its notice, and also to initiate independent investigations in`
  line `such matter;`
  line
  line `(e) to supervise the implementation of the provisions of this Act and rules and regulations made`
  line thereunder;
  line
  line `(f) to recommend to the Board and State Boards about the modifications required in the rules`
  line `and regulations in accordance with changes in technology or social conditions;`
  line
  line `(g) to take action after investigation of complaints received by it against the surrogacy clinics;`
  line and
  line
  line `(h) to consider and grant or reject any application under clause (vi) of section 3 and sub-clauses`
  line `(a) to (c) of clause (iii) of section 4 within a period of ninety days.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (63432)
  sectionNo (37)
  orderNo 37
  title `Powers of appropriate authorities.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63432&sectionno=37&orderno=37&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_37_content:
  string
  line `(1) The appropriate authority shall exercise the powers`
  line `in respect of the following matters, namely:—`
  line
  line `(a) summoning of any person who is in possession of any information relating to violation of`
  line `the provisions of this Act, and rules and regulations made thereunder;`
  line
  line `(b) production of any document or material object relating to clause (a);`
  line
  line `(c) search any place suspected to be violating the provisions of this Act, and the rules and`
  line `regulations made thereunder; and`
  line
  line `(d) such other powers as may be prescribed.`
  line
  line `(2) The appropriate authority shall maintain the details of registration of surrogacy clinics,`
  line `cancellation of registration, renewal of registration, grant of certificates to the intending couple and`
  line `surrogate mothers or any other matter pertaining to grant of license, etc., of the surrogacy clinics in`
  line `such format as may be prescribed and submit the same to the National Assisted Reproductive`
  line `Technology and Surrogacy Board.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (63451)
  sectionNo (38)
  orderNo 38
  title `Prohibition of commercial surrogacy, exploitation of surrogate mothers and children born through surrogacy.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63451&sectionno=38&orderno=38&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_38_content:
  string
  line `(1) No person, organisation, surrogacy clinic, laboratory or clinical`
  line `establishment of any kind shall.—`
  line
  line `(a) undertake commercial surrogacy, provide commercial surrogacy or its related component`
  line `procedures or services in any form or run a racket or an organised group to empanel or select`
  line `surrogate mothers or use individual brokers or intermediaries to arrange for surrogate mothers and`
  line `for surrogacy procedures, at such clinics, laboratories or at any other place;`
  line
  line `(b) issue, publish, distribute, communicate or cause to be issued, published, distributed or`
  line `communicated, any advertisement in any manner regarding commercial surrogacy by any means`
  line `whatsoever, scientific or otherwise;`
  line
  line `(c) abandon or disown or exploit or cause to be abandoned, disowned or exploited in any form,`
  line `the child or children born through surrogacy;`
  line
  line `(d) exploit or cause to be exploited the surrogate mother or the child born through surrogacy in`
  line `any manner whatsoever;`
  line
  line `(e) sell human embryo or gametes for the purpose of surrogacy and run an agency, a racket or`
  line `an organisation for selling, purchasing or trading in human embryos or gametes for the purpose of`
  line surrogacy;
  line
  line `(f) import or shall help in getting imported in, whatsoever manner, the human embryo or human`
  line `gametes for surrogacy or for surrogacy procedures; and`
  line
  line `(g) conduct sex selection in any form for surrogacy.`
  line
  line `(2) Notwithstanding anything contained in the Indian Penal Code (45 of 1860), contraventions of`
  line `the provisions of clauses (a) to (g) of sub-section (1) by any person shall be an offence punishable`
  line `with imprisonment for a term which may extend to ten years and with fine which may extend to ten`
  line `lakh rupees.`
  line
  line `(3) For the purposes of this section, the expression “advertisement” includes any notice, circular,`
  line `label, wrapper or any other document including advertisement through internet or any other media, in`
  line `electronic or print form and also includes any visible representation made by means of any hoarding,`
  line `wall-painting, signal light, sound, smoke or gas.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (63434)
  sectionNo (39)
  orderNo 39
  title `Punishment for contravention of provisions of Act.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63434&sectionno=39&orderno=39&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_39_content:
  string
  line `(1) Any registered medical`
  line `practitioner, gynaecologists, paediatrician, embryologists or any person who owns a surrogacy clinic`
  line `or employed with such a clinic or centre or laboratory and renders his professional or technical`
  line `services to or at such clinic or centre or laboratory, whether on an honorary basis or otherwise, and`
  line `who contravenes any of the provisions of this Act (other than the provisions referred to in section 38)`
  line `and rules and regulations made thereunder shall be punishable with imprisonment for a term which`
  line `may extend to five years and with fine which may extend to ten lakh rupees.`
  line
  line `(2) In case of subsequent or continuation of the offence referred to in sub-section (1), the name of`
  line `the registered medical practitioner shall be reported by the appropriate authority to the State Medical`
  line `Council concerned for taking necessary action including suspension of registration for a period of five`
  line years.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (63435)
  sectionNo (40)
  orderNo 40
  title `Punishment for not following altruistic surrogacy.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63435&sectionno=40&orderno=40&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_40_content:
  string
  line `Any intending couple or intending`
  line `woman or any person who seeks the aid of any surrogacy clinic, laboratory or of a registered medical`
  line `practitioner, gynaecologist, paediatrician, embryologist or any other person for not following the`
  line `altruistic surrogacy or for conducting surrogacy procedures for commercial purposes shall be`
  line `punishable with imprisonment for a term which may extend to five years and with fine which may`
  line `extend to five lakh rupees for the first offence and for any subsequent offence with imprisonment`
  line `which may extend to ten years and with fine which may extend to ten lakh rupees`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (63452)
  sectionNo (41)
  orderNo 41
  title `Penalty for contravention of provisions of Act or rules for which no specific punishment is provided.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63452&sectionno=41&orderno=41&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_41_content:
  string
  line `Whoever contravenes any of the provisions of this Act, rules or regulations made`
  line `thereunder for which no penalty has been provided in this Act, shall be punishable with imprisonment`
  line `for a term which may extend to three years and with fine which may extend to five lakh rupees and in`
  line `the case of continuing contravention with an additional fine which may extend to ten thousand rupees`
  line `for every day during which such contravention continues after conviction for the first such`
  line contravention.
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (63437)
  sectionNo (42)
  orderNo 42
  title `Presumption in the case of surrogacy.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63437&sectionno=42&orderno=42&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_42_content:
  string
  line `Notwithstanding anything contained in the Indian`
  line `Evidence Act, 1872 (1 of 1872), the court shall presume, unless the contrary is proved, that the`
  line `women or surrogate mother was compelled by her husband, the intending couple or any other relative,`
  line `as the case may be, to render surrogacy services, procedures or to donate gametes for the purpose`
  line `other than those specified in clause (ii) of section 4 and such person shall be liable for abetment of`
  line `such offence under section 40 and shall be punishable for the offence specified under that section.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (63438)
  sectionNo (43)
  orderNo 43
  title `Offence to be cognizable, non-baliable and non-compoundable.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63438&sectionno=43&orderno=43&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_43_content:
  string
  line Notwithstanding
  line `anything contained in the Code of Criminal Procedure, 1973 (2 of 1974), every offence under this Act`
  line `shall be cognizable, non-bailable and non-compoundable.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (63439)
  sectionNo (44)
  orderNo 44
  title `Cognizance of offences.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63439&sectionno=44&orderno=44&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_44_content:
  string
  line `(1) No court shall take cognizance of any offence punishable under`
  line `this Act except on a complaint in writing made by--`
  line
  line `(a) the appropriate authority concerned, or any officer or an agency authorised in this behalf by the`
  line `Central Government or the State Government, as the case may be, or the appropriate authority; or`
  line
  line `(b) a person including a social organisation who has given notice of not less that fifteen days in the`
  line `manner prescribed, to the appropriate authority, of the alleged offence and of his intention to make a`
  line `complaint to the court.`
  line
  line `(2) No court inferior to that of a Metropolitan Magistrate or a Judicial Magistrate of the first class`
  line `shall try any offence punishable under this Act.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (63440)
  sectionNo (45)
  orderNo 45
  title `Certain provisions of Code of Criminal Procedure, 1973 not to apply.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63440&sectionno=45&orderno=45&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_45_content:
  string
  line Notwithstanding
  line `anything contained in the Code of Criminal Procedure, 1973 (2 of 1974), Chapter XXI A of the said`
  line `Code relating to plea bargaining shall not apply to the offences under this Act.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (63441)
  sectionNo (46)
  orderNo 46
  title `Maintenance of records.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63441&sectionno=46&orderno=46&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_46_content:
  string
  line `(1) The surrogacy clinic shall maintain all records, charts, forms,`
  line `reports, consent letters, agreements and all the documents under this Act and they shall be preserved`
  line `for a period of twenty-five years or such period as may be prescribed:`
  line
  line `Provided that, if any criminal or other proceedings are instituted against any surrogacy clinic, the`
  line `records and all other documents of such clinic shall be preserved till the final disposal of such`
  line proceedings.
  line
  line `(2) All such records shall, at all reasonable times, be made available for inspection to the`
  line `appropriate authority or to any other person authorised by the appropriate authority in this behalf.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (63442)
  sectionNo (47)
  orderNo 47
  title `Power to search and seize records, etc.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63442&sectionno=47&orderno=47&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_47_content:
  string
  line `(1) If the appropriate authority has reason to`
  line `believe that an offence under this Act has been or is being committed at any surrogacy clinic or any`
  line `other place, such authority or any officer authorised in this behalf may, subject to such rules as may`
  line `be prescribed, enter and search at all reasonable times with such assistance, if any, as such authority`
  line `or officers considers necessary, such surrogacy clinic or any other place and examine any record,`
  line `register, document, book, pamphlet, advertisement or any other material object found therein and`
  line `seize and seal the same if such authority or officer has reason to believe that it may furnish evidence`
  line `of the commission of an offence punishable under this Act.`
  line
  line `(2) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974) relating to search and`
  line `seizure shall apply, as far as may be, to all action taken by the appropriate authority or any officer`
  line `authorised by it under this Act.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (63443)
  sectionNo (48)
  orderNo 48
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63443&sectionno=48&orderno=48&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_48_content:
  string
  line `No suit, prosecution or other legal proceeding`
  line `shall lie against the Central Government or the State Government or the appropriate authority or any`
  line `officer authorised by the Central Government or the State Government or by the appropriate authority`
  line `for anything which is in good faith done or intended to be done in pursuance of the provisions of this`
  line Act.
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (63444)
  sectionNo (49)
  orderNo 49
  title `Application of other laws not barred.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63444&sectionno=49&orderno=49&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_49_content:
  string
  line `The provisions of this Act shall be in addition to,`
  line `and not in derogation of, the provisions of any other law for the time being in force.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (63445)
  sectionNo (50)
  orderNo 50
  title `Power to make rules.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63445&sectionno=50&orderno=50&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_50_content:
  string
  line `(1) The Central Government may, by notification and subject to the`
  line `condition of pre-publication, make rules for carrying out the`
  line `provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for--`
  line
  line `(a) the prescribed expenses under clauses (b), (f) and (q) of sub-section (1) of section 2;`
  line
  line `(b) the minimum qualifications for persons employed at a registered surrogacy clinic under`
  line `clause (iii) of section 3;`
  line
  line `(c) the period and manner in which a person shall store human embryo or gamete under clause`
  line `(vii) of section 3;`
  line
  line `(d) the form and manner of application for obtaining certificate of recommendation from the`
  line `Board under proviso to sub-clause (a) of clause (ii) of section 4;`
  line
  line `(e) the insurance coverage in favour of the surrogate mother from an insurance company and`
  line `the manner of such coverage under item (III) of sub-clause (a) of clause (iii) of section 4;`
  line
  line `(f) the number of attempts of surrogacy or providing of gametes under the proviso to item (III)`
  line `of sub-clause (b) of clause (iii) of section 4;`
  line
  line `(g) the form in which consent of a surrogate mother has to be obtained under clause (ii) of`
  line `section 6;`
  line
  line `(h) the number of oocytes or embryos to be implanted in the uterus of the surrogate mother`
  line `under section 9;`
  line
  line `(i) the conditions under which the surrogate mother may be allowed for abortion during the`
  line `process of surrogacy under section 10;`
  line
  line `(j) the form and manner in which an application shall be made for registration and the fee`
  line `payable thereof under sub-section (2) of section 11;`
  line
  line `(k) the facilities to be provided, equipment and other standards to be maintained by the`
  line `surrogacy clinics under sub-section (4) of section 11;`
  line
  line `(l) the period, manner and form in which a certificate of registration shall be issued under sub-section (1) of section 12;`
  line
  line `(m) the manner in which the certificate of registration shall be renewed and the fee payable for`
  line `such renewal under sub-section (3) of section 12;`
  line
  line `(n) the manner in which an appeal may be preferred under section 14;`
  line
  line `(o) the qualifications and experiences of the Members as admissible under clause (f) of sub-section (2) of section 17;`
  line
  line `(p) the procedures for conducting an inquiry against the Members under sub-section (2) of`
  line `section 21;`
  line
  line `(q) the conditions under which a Member of the Board eligible for re-appointment under`
  line `section 24;`
  line
  line `(r) the other functions of the Board under clause (g) of section 25;`
  line
  line `(s) the manner in which reports shall be furnished by the State Assisted Reproductive`
  line `Technology and Surrogacy Board and the Union territory Assisted Reproductive Technology and`
  line `Surrogacy Board to the Board and the Central Government under clause (iii) of section 26;`
  line
  line `(t) the other functions of the State Board under clause (iv) of section 26;`
  line
  line `(u) the qualifications and experiences of the members as admissible under clause (f) of section`
  line 27;
  line
  line `(v) the age of the person to be appointed as a member, referred to in clause (f) of section 27,`
  line `under the proviso to clause (b) of sub-section (1) of section 28;`
  line
  line `(w) the procedures for conducting an inquiry against the members under sub-section (2) of`
  line `section 31;`
  line
  line `(x) the conditions under which the members of State Board eligible for re-appointment under`
  line `section 34;`
  line
  line `(y) empowering the appropriate authority in any other matter under clause (d) of section 36;`
  line
  line `(z) the other powers of appropriate authority under clause (d) of sub-section (1) of section 37;`
  line
  line `(za) the particulars of the details of registration of surrogacy clinics, cancellation of registration,`
  line `etc., in such format under sub-section (2) of section 37;`
  line
  line `(zb) the manner of giving notice by a person under clause (b) of sub-section (1) of section 44;`
  line
  line `(zc) the period up to which records, charts, etc., shall be preserved under sub-section (1) of`
  line `section 46;`
  line
  line `(zd) the manner in which the seizure of documents, records, objects, etc., shall be made and the`
  line `manner in which seizure list shall be prepared and delivered under sub-section (1) of section 47;`
  line and
  line
  line `(ze) any other matter which is to be, or may be, or in respect of which provision is to be made`
  line `by rules.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (63446)
  sectionNo (51)
  orderNo 51
  title `Power to make regulations.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63446&sectionno=51&orderno=51&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_51_content:
  string
  line `The Board may, with the prior approval of the Central`
  line `Government, by notification, make regulations not inconsistent with the provisions of this Act and the`
  line `rules made thereunder to provide for.—`
  line
  line `(a) the fulfilment of any other condition under which eligibility certificate to be issued by the`
  line `appropriate authority under sub-clause (d) of clause (v) of section 4;`
  line
  line `(b) the time and place of the meetings of the Board and the procedure to be followed for the`
  line `transaction of business at such meetings and the number of Members which shall form the quorum`
  line `under sub-section (1) of section 19;`
  line
  line `(c) the manner in which a person may be temporarily associated with the Board under subsection (1) of section 22;`
  line
  line `(d) the time and place of the meetings of the State Board and the procedure to be followed for`
  line `the transaction of business at such meetings and the number of members which shall form the`
  line `quorum under sub-section (1) of section 29;`
  line
  line `(e) the manner in which a person may be temporarily associated with the Board under subsection (1) of section 32; and`
  line
  line `(f) any other matter which is required to be, or may be, specified by regulations.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (63447)
  sectionNo (52)
  orderNo 52
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63447&sectionno=52&orderno=52&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_52_content:
  string
  line `Every rule made by the Central`
  line `Government and every regulation made by the Board under this Act shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the`
  line `expiry of the session immediately following the session or the successive sessions aforesaid, both`
  line `Houses agree in making any modification in the rule or regulation or both Houses agree that the rule`
  line `or regulation should not be made, the rule or regulation shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule or`
  line `regulation or notification.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (63448)
  sectionNo (53)
  orderNo 53
  title `Transitional provision.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63448&sectionno=53&orderno=53&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_53_content:
  string
  line `Subject to the provisions of this Act, there shall be provided a`
  line `gestation period of ten months from the date of coming into force of this Act to existing surrogate`
  line `mothers' to protect their well being.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (63449)
  sectionNo (54)
  orderNo 54
  title `Power to remove difficulties.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_202147_1643711958603&sectionId=63449&sectionno=54&orderno=54&orgactid=AC_CEN_12_72_00002_202147_1643711958603
obj_root_law_sections_54_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such`
  line `provisions not inconsistent with the provisions of the said Act as appear to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of a period of two years`
  line `from the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament.`
obj_root_law_sections_54_footnotes:
  string
  line
