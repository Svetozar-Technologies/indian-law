obj_root_law_translations_hi:
  title `सेना और वायु सेना (प्राइवेट सम्पत्ति का व्ययन)अधिनियम, 1950`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/2029/2/h195040.pdf`
