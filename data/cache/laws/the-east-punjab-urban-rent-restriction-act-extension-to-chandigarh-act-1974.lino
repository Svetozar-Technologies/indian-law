obj_root_law_sections_1:
  object
  (str sectionId) (str 40355)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the East Punjab Urban Rent Restriction Act (Extension to
Chandigarh) Act, 1974.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00004_197454_1517807320333&sectionId=40355&sectionno=1&orderno=1&orgactid=AC_CEN_18_21_00004_197454_1517807320333)
obj_root_law_sections_2:
  object
  (str sectionId) (str 40356)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definition.)
  (str content) (str `In this Act, "the Act" means the East Punjab Urban Rent Restriction Act, 1949 (East
Punjab Act III of 1949) as it extended to, and was in force in, certain areas in the pre-reorganisation State
of Punjab (being areas which were administered by municipal committees, cantonment boards, town
committees or notified area committees or areas notified as urban areas for the purposes of that Act)
immediately before the 1st day of November, 1966.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00004_197454_1517807320333&sectionId=40356&sectionno=2&orderno=2&orgactid=AC_CEN_18_21_00004_197454_1517807320333)
obj_root_law_sections_3:
  object
  (str sectionId) (str 40357)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Extension of East Punjab Act III of 1949 to Chandigarh.`)
  (str content) (str `Notwithstanding anything contained
in any judgment, decree or order of any court, the Act shall, subject to the modifications specified
in the Schedule, be in force in, and be deemed to have been in force with effect from the 4th day of
November, 1972 in, the Union territory of Chandigarh as if the provisions of the Act as so modified had
been included in and formed part of this section and as if this section had been in force at all material
times.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00004_197454_1517807320333&sectionId=40357&sectionno=3&orderno=3&orgactid=AC_CEN_18_21_00004_197454_1517807320333)
obj_root_law_sections_4:
  object
  (str sectionId) (str 40358)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Validation and saving.`)
  (str content) (str `(1) Notwithstanding anything contained in any judgment, decree or order
of any court, anything done or any action taken (including any notification or direction issued or rents
fixed or permission granted or order made) or purported to have been done or taken under the Act shall be
deemed to be as valid and effective as if the provisions of this Act had been in force at all material times
when such thing was done or such action was taken.

(2) Nothing in this Act shall render any person guilty of any offence for any contravention of the
provisions of the Act which occurred before the commencement of this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00004_197454_1517807320333&sectionId=40358&sectionno=4&orderno=4&orgactid=AC_CEN_18_21_00004_197454_1517807320333)
