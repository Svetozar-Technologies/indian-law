obj_root_law_sections_1:
  sectionId (36650)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Faridabad Development Corporation Act, 1956.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36650&sectionno=1&orderno=1&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (36651)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36651&sectionno=2&orderno=2&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Corporation" means the Faridabad Development Corporation established under section 3;`
  line
  line `(b) "displaced person" means any person who, on account of the setting up of the Dominions of`
  line `India and Pakistan or on account of civil disturbances or the fear of such disturbances in any area now`
  line `forming part of Pakistan, has, after the 1st day of March, 1947, left, or been displaced from, his place`
  line `of residence in such area and who has been subsequently residing in India;`
  line
  line `(c) "Faridabad" means the new township at Faridabad in the district of Gurgaon in the State of`
  line `^1[Haryana], the area of which is described in the Schedule;`
  line
  line `(d) "member" means a member of the Faridabad Development Corporation and includes its`
  line Chairman;
  line `(e) "prescribed" means prescribed by rules made under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by the Punjab Reorganisation and Delhi High Court (Adaptation of Laws on Union Subjects) Order, 1968, for "Punjab"`
  line `(w.e.f. 1-11-1966).`
obj_root_law_sections_3:
  sectionId (36652)
  sectionNo (3)
  orderNo 3
  title Incorporation.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36652&sectionno=3&orderno=3&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such date as the Central Government may, by notification in`
  line `the Official Gazette, appoint in this behalf, there shall be established a Corporation by the name of the`
  line `Faridabad Development Corporation.`
  line
  line `(2) The said Corporation shall be a body corporate having perpetual succession and a common seal,`
  line `and shall by the said name sue and to be sued.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36653)
  sectionNo (4)
  orderNo 4
  title `Constitution of the Corporation.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36653&sectionno=4&orderno=4&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_4_content:
  string
  line `The Corporation shall consist of a Chairman and such other`
  line `members, being not less than four and not more than eight, as the Central Government may, by`
  line `notification in the Official Gazette, appoint.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36654)
  sectionNo (5)
  orderNo 5
  title `Term and conditions of service of member.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36654&sectionno=5&orderno=5&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_5_content:
  string
  line `(1) The term of office and conditions of service of`
  line `the Chairman and other members shall be such as may be prescribed.`
  line
  line `(2) The Chairman or any other member may resign his office by writing under his hand addressed to`
  line `the Central Government, but he shall continue in office until the appointment of his successor is notified`
  line `in the Official Gazette.`
  line
  line `(3) A casual vacancy created by the resignation of the Chairman or any other member under`
  line `sub-section (2) or for any other reason shall be filled by fresh appointment.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36655)
  sectionNo (6)
  orderNo 6
  title `Disqualification for being appointed, or for continuing as, member of the Corporation.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36655&sectionno=6&orderno=6&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_6_content:
  string
  line A
  line `person shall be disqualified for being appointed or for continuing as a member of the Corporation if he has, directly or indirectly, any interest in a subsisting contract made with, or in any work being done, for,`
  line `the Corporation except as a shareholder (other than a director) in an incorporated company:`
  line
  line `Provided that where he is a shareholder, he shall disclose to the Central Government the nature and`
  line `extent of shares held by him in such company.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36656)
  sectionNo (7)
  orderNo 7
  title `Temporary absence of any member.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36656&sectionno=7&orderno=7&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_7_content:
  string
  line `If any member of the Corporation is by infirmity or`
  line `otherwise rendered temporarily incapable of carrying out his duties or is absent on leave or otherwise in`
  line `circumstances not involving the vacation of his appointment, the Central Government may appoint`
  line `another person to act in his place during his absence.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (36686)
  sectionNo (8)
  orderNo 8
  title `Vacancies amongst members or defect in the constitution not to invalidate acts or proceedings of the Corporation.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36686&sectionno=8&orderno=8&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_8_content:
  string
  line `No act or proceeding of the Corporation shall be invalid by reason`
  line `only of the existence of any vacancy amongst its members or any defect in the constitution thereof.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36658)
  sectionNo (9)
  orderNo 9
  title `Committees of the Corporation.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36658&sectionno=9&orderno=9&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_9_content:
  string
  line `The Corporation may constitute such committees for general`
  line `or special purposes as the Corporation deems necessary to carry out the purposes of this Act.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (36659)
  sectionNo (10)
  orderNo 10
  title `Meetings of the Corporation.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36659&sectionno=10&orderno=10&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_10_content:
  string
  line `(1) The Corporation shall meet for the transaction of business at`
  line `such times and places as may be prescribed:`
  line
  line `Provided that the Chairman may, whenever he thinks fit, and shall, upon the written requisition of not`
  line `less than two members, call a special meeting.`
  line
  line `(2) The Chairman or, in his absence, any member chosen by the members present from among`
  line `themselves, shall preside at a meeting of the Corporation.`
  line
  line `(3) All questions which come before any meeting of the Corporation shall be decided by majority of`
  line `votes of the members present, and in the case of an equality of votes, the Chairman, or in his absence, any`
  line `other person presiding, shall have a second or casting vote.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (36660)
  sectionNo (11)
  orderNo 11
  title `Authentication of orders and other instruments of the Corporation.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36660&sectionno=11&orderno=11&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_11_content:
  string
  line `All orders and`
  line `decisions of the Corporation shall be authenticated by the signature of the Chairman or any other member`
  line `authorised by the Corporation in this behalf, and all other instruments issued by the Corporation shall be`
  line `authenticated by the signature of the Administrator or any other officer of the Corporation authorised in`
  line `like manner in this behalf.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (36661)
  sectionNo (12)
  orderNo 12
  title `Appointment of Administrator and other officer of the Corporation.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36661&sectionno=12&orderno=12&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_12_content:
  string
  line `(1) There shall be an`
  line `Administrator of the Corporation who shall be appointed by the Central Government.`
  line
  line `(2) The Administrator shall be the chief executive officer of the Corporation and all other officers of`
  line `the Corporation shall be subordinate to him.`
  line
  line `(3) The Administrator shall have the right to take part in the discussions of the Corporation or of any`
  line `of its committees but shall not have the right to vote at the meetings of the Corporation or of any of its`
  line `committees:`
  line
  line `Provided that when one of the members of the Corporation is appointed under`
  line `sub-section (1) as the Administrator, such Administrator shall have all the rights and privileges of a`
  line member.
  line
  line `(4) The Corporation may appoint such other officers as it may consider necessary for the efficient`
  line `performance of its functions under this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (36662)
  sectionNo (13)
  orderNo 13
  title `General duty of the Corporation.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36662&sectionno=13&orderno=13&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_13_content:
  string
  line `It shall be the general duty of the Corporation to carry on`
  line `and promote trade, business and industry in Faridabad, to assist in the rehabilitation of displaced persons`
  line `settled therein and to manage and develop the property of the Union vested in the Corporation.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (36663)
  sectionNo (14)
  orderNo 14
  title `Powers of the Corporation.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36663&sectionno=14&orderno=14&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_14_content:
  string
  line `(1) The Corporation may exercise all such powers as may be`
  line `necessary or expedient for the purpose of carrying out its functions under this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing provision, such power shall include the`
  line power--
  line
  line `(a) to acquire and hold such property, both movable and immovable, as the Corporation may`
  line `deem necessary for efficiently performing its functions under this Act and to make improvements in`
  line `such property and to transfer by way of sale, lease or otherwise any such property;`
  line
  line `(b) to carry on or promote any trade, business or industry;`
  line
  line `(c) to give financial or other assistance to persons to enable them to carry on trade, business or`
  line `industry in Faridabad primarily with a view to providing employment to, and rehabilitating, displaced`
  line `persons settled therein;`
  line
  line `(d) to construct or cause to be constructed residential or other buildings and to sell or let such`
  line `buildings or cause them to be sold or let, on such terms as may be prescribed;`
  line
  line `(e) to advance loans on such terms and for such purposes as may be prescribed;`
  line
  line `(f) to supply or cause to be supplied, in accordance with the law for the time being in force,`
  line `electrical energy for domestic and industrial purposes at reasonable rates;`
  line
  line `(g) to take such other measures as the Corporation may deem necessary for the rehabilitation of`
  line `displaced persons settled in Faridabad;`
  line
  line `(h) to take such steps as may be necessary for improving the economic and social conditions of`
  line `the inhabitants of Faridabad.`
  line
  line `(3) Nothing in this section shall affect the exercise of any power or the performance of any function`
  line `by any local authority having jurisdiction in Faridabad.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (36664)
  sectionNo (15)
  orderNo 15
  title `Capital of the Corporation.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36664&sectionno=15&orderno=15&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_15_content:
  string
  line `All non-recurring expenditure incurred by the Central Government`
  line `or the body known as the Faridabad Development Board for and in connection with the development of`
  line `Faridabad or for any of the purposes referred to in this Act upto the date of the establishment of the`
  line `Corporation and declared to be capital expenditure by the Central Government shall be treated as the`
  line `capital provided by the Central Government to the Corporation.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (36665)
  sectionNo (16)
  orderNo 16
  title `Grants and loans to the Corporation.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36665&sectionno=16&orderno=16&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_16_content:
  string
  line `The Central Government may, after due appropriation`
  line `made by Parliament by law in this behalf, make such grants and advance such loans to the Corporation as`
  line `the Central Government may deem necessary for the performance of the functions of the Corporation`
  line `under this Act; and all grants made and all loans advanced shall be on such terms and conditions as the`
  line `Central Government may determine.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (36666)
  sectionNo (17)
  orderNo 17
  title `Vesting of property in the Corporation.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36666&sectionno=17&orderno=17&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_17_content:
  string
  line `All property, assets and funds owned or acquired by`
  line `the Central Government or purporting to have been owned or acquired by the body known as the`
  line `Faridabad Development Board for the purposes of the development of Faridabad or for any of the`
  line `purposes referred to in this Act before the establishment of the Corporation shall, on such establishment,`
  line `vest in the Corporation unless the Central Government otherwise directs in respects of any part of such`
  line `property, assets or funds.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (36667)
  sectionNo (18)
  orderNo 18
  title `Repayment of capital and loan with interest.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36667&sectionno=18&orderno=18&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_18_content:
  string
  line `The Corporation shall repay, at such intervals`
  line `and on such terms as the Central Government may determine, the amount of capital provided under`
  line `section 15 and all loans advanced under section 16 with interest at such rate as may, from time to time, be`
  line `fixed by that Government and such repayment of capital or loan or payment of interest shall be deemed to`
  line `be part of the expenditure of the Corporation.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (36668)
  sectionNo (19)
  orderNo 19
  title `Corporation to have rights and liabilities of the Central Government in certain cases.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36668&sectionno=19&orderno=19&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_19_content:
  string
  line `(1)`
  line `All rights, liabilities and obligations of the Central Government which, whether arising out of any`
  line `contract or otherwise, were acquired or incurred by it in connection with any transaction for the`
  line `development of Faridabad or for any of the purposes referred to in this Act before the establishment of the`
  line `Corporation, shall be deemed to have been acquired or incurred by the Corporation and shall be the rights,`
  line `liabilities and obligations, respectively, of the Corporation.`
  line
  line `(2) All suits or other legal proceedings instituted or which might but for the issue of the notification`
  line `under sub-section (1) of section 3 has been instituted by or against the Central Government may be`
  line `continued or instituted by or against the Corporation.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (36669)
  sectionNo (20)
  orderNo 20
  title `Fund of the Corporation.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36669&sectionno=20&orderno=20&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_20_content:
  string
  line `(1) The Corporation shall have its own Fund and all receipts of the`
  line `Corporation shall be carried thereto and all payments by the Corporation shall be made therefrom.`
  line
  line `(2) All moneys belonging to the Fund shall be deposited in such bank or invested in such manner as`
  line `may be decided by the Corporation.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (36670)
  sectionNo (21)
  orderNo 21
  title `Provision for depreciation and reserve and other funds.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36670&sectionno=21&orderno=21&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_21_content:
  string
  line `(1) The Corporation shall make such`
  line `provision for depreciation and for reserve and other funds as the Central Government may from time to`
  line `time direct.`
  line
  line `(2) The management of these funds, the sums to be carried from time to time to the credit thereof and`
  line `the application of the moneys comprised therein shall be determined in accordance with such directions as`
  line `the Central Government may from time to time issue.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (36671)
  sectionNo (22)
  orderNo 22
  title `Power of the Corporation to spend.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36671&sectionno=22&orderno=22&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_22_content:
  string
  line `The Corporation shall have power to spend such sums as`
  line `it thinks fit for performing its functions under this Act, and such sums shall be treated as expenditure`
  line `payable out of the Fund of the Corporation.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (36672)
  sectionNo (23)
  orderNo 23
  title Budget.
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36672&sectionno=23&orderno=23&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_23_content:
  string
  line `The Corporation shall prepare, in such form and at such time each year as may be`
  line `prescribed, a budget in respect of every financial year next ensuing showing the estimated receipts and`
  line `expenditure, and copies thereof shall be forwarded to the Central Government.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (36673)
  sectionNo (24)
  orderNo 24
  title `Annual report.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36673&sectionno=24&orderno=24&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_24_content:
  string
  line `The Corporation shall prepare in such form and at such time each year as may`
  line `be prescribed an annual report giving a true and full account of its activities during the previous financial`
  line `year and copies thereof shall be sent to the Central Government and the Government of the State of`
  line Punjab.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (36674)
  sectionNo (25)
  orderNo 25
  title `Accounts and audit.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36674&sectionno=25&orderno=25&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_25_content:
  string
  line `(1) The Corporation shall cause to be maintained such books of account`
  line `and other books in relation to its accounts in such form and in such manner as may be prescribed.`
  line
  line `(2) The accounts of the Corporation shall be audited at such times and in such manner as may be`
  line prescribed.
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (36675)
  sectionNo (26)
  orderNo 26
  title `Amount due to the Corporation to be first charge.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36675&sectionno=26&orderno=26&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_26_content:
  string
  line `(1) Notwithstanding anything contained in`
  line `any other law, where a loan has been advanced to any person for the construction of a building or where a`
  line `building has been transferred to any person, the amount due to the Corporation on account of the loan or`
  line `transfer together with interest thereon shall be a first charge on the building so constructed or transferred.`
  line
  line `(2) The Corporation may also take such further security as it may consider necessary for advancing`
  line `any loan or for transferring any building.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (36676)
  sectionNo (27)
  orderNo 27
  title Direction.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36676&sectionno=27&orderno=27&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_27_content:
  string
  line `For the purposes of this Act, the Central Government may, from time to time, give to`
  line `the Corporation such general or special directions as the Central Government thinks fit and in the`
  line `performance of the functions, the Corporation shall comply with such directions.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (36677)
  sectionNo (28)
  orderNo 28
  title `Returns and reports.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36677&sectionno=28&orderno=28&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_28_content:
  string
  line `The Corporation shall furnish to the Central Government such returns,`
  line `statistics, accounts and other information with respect to its property or activities as the Central`
  line `Government may from time to time require.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (36678)
  sectionNo (29)
  orderNo 29
  title `Mode of recovery of moneys due to the Corporation.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36678&sectionno=29&orderno=29&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_29_content:
  string
  line `When any money is due to the`
  line `Corporation from any person, then, without prejudice to any other mode of recovery, the Corporation`
  line `may, after giving that person an opportunity of being heard, issue a certificate to the Collector of the`
  line `amount due and the Collector shall proceed to recover that amount in the same manner as an arrear of`
  line `land revenue.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (36679)
  sectionNo (30)
  orderNo 30
  title `Delegation of powers.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36679&sectionno=30&orderno=30&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_30_content:
  string
  line `The Corporation may, by general or special order in writing, delegate to`
  line `the Chairman or any other member or any officer of the Corporation, subject to such conditions and`
  line `limitations (if any) as may be specified in the order, such of its powers and duties under this Act as it may`
  line `deem necessary for the efficient running of the day-to-day administration of the Corporation.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (36680)
  sectionNo (31)
  orderNo 31
  title `Members and officers of the Corporation to be public servants.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36680&sectionno=31&orderno=31&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_31_content:
  string
  line `All members and officers of`
  line `the Corporation shall, when acting or purporting to act in pursuance of any of the provisions of this Act,`
  line `be deemed to be public servants within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (36681)
  sectionNo (32)
  orderNo 32
  title `Removal of disqualification for membership of Parliament.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36681&sectionno=32&orderno=32&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_32_content:
  string
  line `It is hereby declared that the`
  line `office of the member of the Corporation shall not disqualify its holder for being chosen as, or for being, a`
  line `member of either House of Parliament.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (36682)
  sectionNo (33)
  orderNo 33
  title `Bar of legal proceedings.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36682&sectionno=33&orderno=33&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_33_content:
  string
  line `No suit or other legal proceedings shall lie against any member or`
  line `officer of the Corporation in respect of anything which is in good faith done or intended to be done in`
  line `pursuance of this Act.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (36683)
  sectionNo (34)
  orderNo 34
  title `Validation of certain transactions.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36683&sectionno=34&orderno=34&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_34_content:
  string
  line `On the establishment of the Corporation under`
  line `section 3,--`
  line
  line `(a) all action purporting to have been taken, and all transactions purporting to have been made, by`
  line `or with the body known as the Faridabad Development Board (including any action or transaction by`
  line `which any property, asset or right was purported to have been acquired or any liability or obligation,`
  line `whether by contract or otherwise, was purported to have been incurred) shall be deemed to have been`
  line `validly and lawfully taken or made by or with the Corporation as if this Act were in force and the`
  line `Corporation were in existence on the day on which such action was taken or transaction was made;`
  line and
  line
  line `(b) in particular, and without prejudice to the generality of the foregoing provision,--`
  line
  line `(i) all property and assets vesting in the body known as the Faridabad Development Board`
  line `shall vest in the Corporation;`
  line
  line `(ii) all rights, liabilities and obligations of the body known as the Faridabad Development`
  line `Board, whether arising out of any contract or otherwise, shall be the rights, liabilities and`
  line `obligations, respectively, of the Corporation; and`
  line
  line `(iii) all leases granted by, all contracts made with, and all instruments executed on behalf of,`
  line `the body known as the Faridabad Development Board shall be deemed to have been granted by,`
  line `made with, or executed on behalf of, the Corporation and shall have effect accordingly.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (36684)
  sectionNo (35)
  orderNo 35
  title `Power to remove difficulties.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36684&sectionno=35&orderno=35&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_35_content:
  string
  line `If any doubt or difficulty arises in giving effect to the provisions`
  line `of this Act, the Central Government may, by order, make such provision or give such direction, not`
  line `inconsistent with the provisions of this Act, as may appear to it to be necessary or expedient for the`
  line `removal of the doubt or difficulty, and the order of the Central Government, in such cases, shall be final.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (36685)
  sectionNo (36)
  orderNo 36
  title `Power to make rules.`
  content obj_root_law_sections_36_content
  footnotes `1. Subs. by Act 4 of 2005, s. 2 and the Schedule, for sub-section (3) (w.e.f. 11-1-2005).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00006_195690_1517807325168&sectionId=36685&sectionno=36&orderno=36&orgactid=AC_CEN_25_35_00006_195690_1517807325168
obj_root_law_sections_36_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the term of office and other conditions of service of members;`
  line
  line `(b) the terms and conditions of service of the Administrator and other officers of the Corporation;`
  line
  line `(c) meetings of the Corporation and the procedure for conducting business thereat;`
  line
  line `(d) the intervals at which, and the terms on which, the capital provided or loan advanced by the`
  line `Central Government to the Corporation may be repaid, and the rate at which interest may be paid on`
  line `the capital provided or loan advanced by the Central Government;`
  line
  line `(e) the form and manner in which the budget and the annual report may be prepared;`
  line
  line `(f) the manner in which the accounts of the Corporation may be maintained and audited;`
  line
  line `(g) the form and manner in which returns, statistics, accounts and other information may be`
  line `furnished to the Central Government;`
  line
  line `(h) any other matter which has to be, or may be, prescribed under this Act.`
  line
  line `^1[(3) Every rule made by the Central Government under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `फरीदाबाद विकास निगम अधिनियम, 1956`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1729/3/H1956-90.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T09:41:58.440Z`
  pageCount 6
  sections obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
  obj_root_law_translations_hi_sections_3
