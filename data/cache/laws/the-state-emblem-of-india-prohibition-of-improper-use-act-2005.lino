obj_root_law_translations_hi_sections_5_content:
  string
  line 4
  line `पररचशष्ट – 1`
  line `रटप् प ण: यह चििाइन सरलीकृत रू प में है और लघु आकार में िैसे लेिन सामग्री, मुरा और ठप्पा मुरण में पुन:प्रस् तु तीकरण के`
  line `चलए है।`
obj_root_law_translations_hi_sections_5_footnotes:
  string
  line
obj_root_law_translations_hi_sections_6:
  kind page
  sectionId pdf-page-6
