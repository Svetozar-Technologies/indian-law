obj_root_law:
  slug the-betwa-river-board-act-1976
  handle (1479)
  collectionHandle 123456789/1362
  title `The Betwa River Board Act, 1976`
  actNumber (63)
  enactmentDate 1976-04-10
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1479`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `बेतवा नदी बोर्ड अधिनियम, 1976`
