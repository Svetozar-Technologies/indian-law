  (str title) (str `The Betwa River Board Act, 1976`)
  (str actNumber) (str 63)
  (str enactmentDate) (str 1976-04-10)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1479`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बेतवा नदी बोर्ड अधिनियम, 1976`)
  (str actYear) (str 1976)
  (str ministry) (str `Ministry of Jal Shaktri`)
  (str department) (str `Department of Water Resources, River Development and Ganga Rejuvenation`)
  (str longTitle) (str `An Act to provide for the establishment of a Board for the creation of a reservoir at Rajghat by construction, on behalf of the Governments of Madhya Pradesh and Uttar Pradesh, of a dam on the Betwa river at Rajghat and for the regulation of such reservoir.`)
