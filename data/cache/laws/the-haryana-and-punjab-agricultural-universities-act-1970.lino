obj_root_law_sections_1:
  sectionId (30340)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30340&sectionno=1&orderno=1&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Haryana and Punjab`
  line `Agricultural Universities Act, 1970.`
  line
  line `(2) It shall be deemed to have come into force on the 2nd day of February, 1970.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (30341)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30341&sectionno=2&orderno=2&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made thereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council" means, in relation to a corresponding University, the Academic Council`
  line `of that University;`
  line
  line `(b) "agriculture" includes the basic and applied science of soil and water management, crop and`
  line `live-stock production and management, home sciences and the betterment of rural people;`
  line
  line `(c) "appropriate Government" means,--`
  line
  line `(i) in relation to the Haryana Agricultural University, the Government of the State of`
  line Haryana;
  line
  line `(ii) in relation to the Punjab Agricultural University, the Government of the State of Punjab;`
  line
  line `(d) "Board", in relation to a corresponding University, means the Board of Management of that`
  line University;
  line
  line `(e) "college" means a constituent college of a corresponding University;`
  line
  line `(f) "corresponding University" means,--`
  line
  line `(i) in relation to the territories to which the functions of the Haryana Agricultural University`
  line `extend, that University;`
  line
  line `(ii) in relation to the territories to which the functions of the Punjab Agricultural University`
  line `extend, that University;`
  line
  line `(g) "existing University" means the Punjab Agricultural University constituted by section 3 of the`
  line `Punjab Agricultural University Act, 1961 (Punjab Act 32 of 1961);`
  line
  line `(h) "library" means a library established or maintained by a corresponding University;`
  line
  line `(i) "prescribed" means prescribed by the Statutes of a corresponding University;`
  line
  line `(j) "Statutes" and "Regulations" mean, respectively, the Statutes and Regulations made by a`
  line `corresponding University under this Act;`
  line
  line `(k) "transferred territories" means the territories added to the Union territory of Himachal Pradesh`
  line `by sub-section (1) of section 5 of the Punjab Reorganisation Act, 1966 (31 of 1966);`
  line
  line `(l) "Vice-Chancellor" means the Vice-Chancellor of a corresponding University.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (30342)
  sectionNo (3)
  orderNo 3
  title `Dissolution of the existing University and establishment of Haryana and Punjab Agricultural Universities.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30342&sectionno=3&orderno=3&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_3_content:
  string
  line `As from the commencement of this Act, the existing University shall stand dissolved and`
  line `there shall be established in its place two independent Agricultural Universities, to be known respectively`
  line `as the Haryana Agricultural University and the Punjab Agricultural University.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (30343)
  sectionNo (4)
  orderNo 4
  title Incorporation.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30343&sectionno=4&orderno=4&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_4_content:
  string
  line `(1) Each of the Agricultural Universities mentioned in section 3 shall be a body`
  line `corporate having perpetual succession and a common seal with power to acquire, hold and dispose of`
  line `property, and to contract, and may, by its name, sue and be sued.`
  line
  line `(2) Each body corporate referred to in sub-section (1) shall consist of the Chancellor and the`
  line `Vice-Chancellor of that University, the members of the Board, the Academic Council and all persons,`
  line `who may hereafter become or be appointed as such officers or members, so long as they continue to hold`
  line `such office or membership.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (30344)
  sectionNo (5)
  orderNo 5
  title `Territorial limits.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30344&sectionno=5&orderno=5&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_5_content:
  string
  line `(1) The Haryana Agricultural University shall function within the territories`
  line `of the State of Haryana and the Punjab Agricultural University shall function within such other territories`
  line `to which the functions of the existing University extended immediately before the commencement of this`
  line `Act:`
  line
  line `Provided that on the establishment of a University in the Union territory of Himachal Pradesh, the`
  line `Punjab Agricultural University shall cease to function in the transferred territories.`
  line
  line `(2) Until a University is established in the Union territory of Himachal Pradesh, the Agricultural`
  line `College at Palampur in the transferred territories shall, notwithstanding the dissolution of the existing`
  line `University, continue to be a college of the Punjab Agricultural University and shall cease to be such`
  line `college on the establishment of a University in those territories.`
  line
  line `(3) On the establishment of a University in the Union territory of Himachal Pradesh, the assets and`
  line `liabilities of the Punjab Agricultural University pertaining to the Agricultural College at Palampur, all`
  line `research, training and extension centres, and any other property, of the Punjab Agricultural University`
  line `located in the said Union territory shall stand transferred to, and shall vest in, such University.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (30345)
  sectionNo (6)
  orderNo 6
  title Headquarters.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30345&sectionno=6&orderno=6&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_6_content:
  string
  line `(1) The headquarters of the Haryana Agricultural University shall be at Hissar,`
  line `and the headquarters of the Punjab Agricultural University shall be at Ludhiana, or at such other place as`
  line `the appropriate Government may direct.`
  line
  line `(2) Each corresponding University shall establish an office at the place at which the seat of the`
  line `appropriate Government is located.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (30346)
  sectionNo (7)
  orderNo 7
  title `Objects of corresponding University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30346&sectionno=7&orderno=7&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_7_content:
  string
  line `Each corresponding University shall be deemed to be`
  line `established and incorporated for the following objects, namely:--`
  line
  line `(a) making provision for imparting education in different branches of study, particularly`
  line `agriculture, veterinary and animal science, agricultural engineering, home sciences and other allied`
  line sciences;
  line
  line `(b) furthering the advancement of learning and prosecution of research, particularly in agriculture`
  line `and other allied sciences;`
  line
  line `(c) undertaking the extension of such sciences to the rural people of the territories within which`
  line `the University is required by this Act to function;`
  line
  line `(d) such other purposes as the appropriate Government may, by notification in the Official`
  line `Gazette, direct.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (30347)
  sectionNo (8)
  orderNo 8
  title `Admission to a corresponding University.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30347&sectionno=8&orderno=8&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_8_content:
  string
  line `(1) Each corresponding University shall, subject to`
  line `the provisions of this Act and the Statutes, be open to all persons:`
  line
  line `Provided that nothing herein shall require any such University to admit to any course of study a`
  line `number of students larger than the prescribed number.`
  line
  line `(2) The appropriate Government may direct the corresponding University to reserve in any college`
  line `seats for women, Scheduled Castes, Scheduled Tribes or such educationally backward classes of citizens`
  line `as may be specified by that Government in this behalf, and where such direction has been given, the`
  line `corresponding University shall make the reservations accordingly:`
  line
  line `Provided that no such person shall be entitled to be admitted to a corresponding University unless he`
  line `meets the standards laid down by the corresponding University.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (30348)
  sectionNo (9)
  orderNo 9
  title `Powers of a corresponding University.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30348&sectionno=9&orderno=9&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_9_content:
  string
  line `Each corresponding University shall have the following`
  line `powers, namely:--`
  line
  line `(a) to provide for graduate and post-graduate instructions in agriculture, veterinary and animal`
  line `sciences, agricultural engineering, home sciences and other allied sciences and in such other branches`
  line `of learning as the University may deem fit;`
  line
  line `(b) to make provision for instructions in applied fields, research and the dissemination of the`
  line `findings of research and technical information through an extension education programme;`
  line
  line `(c) to institute degrees, diplomas and other academic distinctions;`
  line
  line `(d) to hold examinations and to grant and confer degrees, diplomas and other academic`
  line `distinctions to and on persons who shall have--`
  line
  line `(i) pursued a prescribed course of study; or`
  line
  line `(ii) carried out research in the University, or in an institution recognised in this behalf by the`
  line `University, under the prescribed conditions;`
  line
  line `(e) to confer honorary degrees or other distinctions in the prescribed manner and under the`
  line `prescribed conditions;`
  line
  line `(f) to provide lectures and instructions for field workers, village leaders and other persons not`
  line `enrolled as regular students of the University and to grant certificates to them when deemed desirable;`
  line
  line `(g) to co-operate with other Universities and authorities in such manner and for such purposes as`
  line `the University may determine;`
  line
  line `(h) to institute teaching, research and extension education posts required by the University and to`
  line `appoint persons to such posts;`
  line
  line `(i) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(j) to institute and award fellowships, scholarships and prizes in accordance with the Statutes;`
  line
  line `(k) to institute and maintain residential accommodation for students of the University;`
  line
  line `(l) to supervise and control the residential accommodation and to regulate the discipline of the`
  line `students of the University and to make arrangements for promoting their health and welfare;`
  line
  line `(m) to institute and receive such fees and other charges as may prescribed; and`
  line
  line `(n) to do all such acts and things, whether incidental to the powers aforesaid or not, as may be`
  line `requisite in order to further the objects of the University.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (30349)
  sectionNo (10)
  orderNo 10
  title Visitations.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30349&sectionno=10&orderno=10&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_10_content:
  string
  line `(1) The Chancellor of a corresponding University may cause an inspection to be`
  line `made by such person as he may direct, of the corresponding University, its buildings, laboratories, and`
  line `equipment and of any institution maintained by that University, and may cause an inquiry to be made in`
  line `respect of any matter connected with the administration and the finances of that University.`
  line
  line `(2) The Chancellor of a corresponding University shall, in every case, give notice to the University of`
  line `his intention to cause an inspection or inquiry to be made, and, on receipt of such notice, that University`
  line `shall be entitled to appoint a representative who shall have the right to be present, and heard, at such`
  line `inspection or inquiry..`
  line
  line `(3) The Chancellor of a corresponding University may address the Board of the University with`
  line `reference to the result of such inspection or inquiry with such advice as he may offer regarding the action`
  line `to be taken..`
  line
  line `(4) The Board shall communicate to the Chancellor such action as it proposes to take or has taken as`
  line `the result of such inspection or inquiry..`
  line
  line `(5) If the Board does not, within a reasonable time, take action to the satisfaction of the Chancellor,`
  line `he may, after considering any explanation furnished or representation made by the Board, issue such`
  line `directions as he may deem fit, and the Board shall comply with such directions.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (30350)
  sectionNo (11)
  orderNo 11
  title `Authorities and officers of a corresponding University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30350&sectionno=11&orderno=11&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_11_content:
  string
  line `The following shall be the authorities`
  line `and officers of each corresponding University, namely:--`
  line
  line `(a) Authorities of a corresponding University--`
  line
  line `(i) Board;`
  line
  line `(ii) Academic Council;`
  line
  line `(iii) Board of Studies; and`
  line
  line `(iv) Such other authorities as may be declared by the Statutes to be authorities of the`
  line University.
  line
  line `(b) Officers of the corresponding University--`
  line
  line `(i) Chancellor;`
  line
  line `(ii) Vice-Chancellor;`
  line
  line `(iii) Dean of Post-Graduate Studies;`
  line
  line `(iv) Deans of the colleges;`
  line
  line `(v) Director of Research;`
  line
  line `(vi) Director of Agricultural Extension Education;`
  line
  line `(vii) Director of Students Welfare;`
  line
  line `(viii) Registrar;`
  line
  line `(ix) Comptroller;`
  line
  line `(x) Estate Officer;`
  line
  line `(xi) Librarian; and`
  line
  line `(xii) Such other persons in the service of the University as may be declared by the Statutes to`
  line `be officers of the University.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (30351)
  sectionNo (12)
  orderNo 12
  title Chancellor.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30351&sectionno=12&orderno=12&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_12_content:
  string
  line `(1) The Governor of the State of Haryana shall be the Chancellor of the Haryana`
  line `Agricultural University and the Governor of the State of Punjab shall be the Chancellor of the Punjab`
  line `Agricultural University.`
  line
  line `(2) The Chancellor of a corresponding University shall, by virtue of his office, be the Head of that`
  line `University and shall, when present, preside at a convocation of that University.`
  line
  line `(3) The Chancellor of a corresponding University shall have such other powers as are specified in this`
  line `Act or as may be prescribed.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (30352)
  sectionNo (13)
  orderNo 13
  title `Constitution, powers and duties of the Board of a corresponding University.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30352&sectionno=13&orderno=13&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_13_content:
  string
  line `(1) The`
  line `appropriate Government shall, within a period of one year from the commencement of this Act, establish`
  line `a Board for the management of the corresponding University.`
  line
  line `(2) The Board of the Haryana Agricultural University shall consist of--`
  line
  line `(a) the Vice-Chancellor;`
  line
  line `(b) the Chief Secretary to the Government of the State of Haryana;`
  line
  line `(c) the Secretaries to the Government of the State of Haryana in the Departments of--`
  line
  line `(i) Agriculture;`
  line
  line `(ii) Finance; and`
  line
  line `(iii) Community Development;`
  line
  line `(d) persons, not being officials, appointed by the Government of the State of Haryana from`
  line `amongst the following categories of persons, namely:--`
  line
  line `(i) one from amongst persons who are, in the opinion of that Government, eminent`
  line `agricultural scientists with a background of agricultural research or education;`
  line
  line `(ii) two from amongst persons who are, in the opinion of that Government, progressive`
  line `farmers or live-stock breeders having experience of, and interest in scientific farming and livestock improvement;`
  line
  line `(iii) one from amongst persons who are, in the opinion of that Government, distinguished`
  line `industrialists, businessmen, manufacturers or live-stock breeders, associated with agricultural`
  line `development; and`
  line
  line `(iv) one from amongst women who are, in the opinion of that Government, outstanding social`
  line `workers, preferably with a background of rural advancement.`
  line
  line `(3) The Board of the Punjab Agricultural University shall consist of--`
  line
  line `(a) the Vice-Chancellor;`
  line
  line `(b) the Chief Secretary to the Government of the State of Punjab;`
  line
  line `(c) the Secretaries to the Government of the State of Punjab in the Departments of--`
  line
  line `(i) Agriculture; and`
  line
  line `(ii) Finance;`
  line
  line `(d) the Director of Agriculture, Punjab;`
  line
  line `(e) the Director of Animal Husbandry, Punjab;`
  line
  line `(f) one nominee of the Indian Council of Agricultural Research;`
  line
  line `(g) two nominees of the Government of the Union territory of Himachal Pradesh;`
  line
  line `(h) persons, not being officials, appointed by the Government of the State of Punjab from`
  line `amongst the following categories of persons, namely:--`
  line
  line `(i) two from amongst persons who are, in the opinion of that Government, eminent`
  line `agricultural scientists with a background of agricultural research or education;`
  line
  line `(ii) two from amongst persons who are, in the opinion of that Government, progressive`
  line `farmers or live-stock breeders having experience of, and interest in, scientific farming and`
  line `live-stock improvement;`
  line
  line `(iii) one from amongst persons who are, in the opinion of that Government, distinguished`
  line `industrialists, businessmen, manufacturers or live-stock breeders, associated with agricultural`
  line `development; and`
  line
  line `(iv) one from amongst women who are, in the opinion of that Government, outstanding social`
  line `workers, preferably with a background of rural advancement.`
  line
  line `(4) The Board of the Haryana Agricultural University shall associate with its meeting the following`
  line `persons as technical advisers, but the persons so associated shall not be entitled to vote at any such`
  line meeting.--
  line
  line `(a) the Director of Agriculture, Haryana;`
  line
  line `(b) the Director of Animal Husbandry, Haryana; and`
  line
  line `(c) two officers appointed by the Board of that University from amongst the Deans or Directors of`
  line `that University.`
  line
  line `(5) The term of office of the members of the Board, other than the official members, shall be three`
  line `years:`
  line
  line `Provided that two members of the Board, not being official members, shall retire at the end of each`
  line year.
  line
  line `(6) The members of the Board, other than the official members, shall determine, by lots, the members`
  line `who shall retire at the end of each year.`
  line
  line `(7) A member of the Board may resign his office by a notice in writing, addressed to the Chancellor`
  line `of the corresponding University.`
  line
  line `(8) If, for any reason, a vacancy occurs in the office of a member of the Board, the appropriate`
  line `Government may fill the vacancy by appointing another person thereto in accordance with the provisions`
  line `of this section.`
  line
  line `(9) No act or proceeding of the Board shall be invalid merely on the ground of the existence of any`
  line `vacancy in, or defect in the constitution of, such Board.`
  line
  line `(10) Four members of the Board, in the case of the Haryana Agricultural University, and five`
  line `members of the Board, in the case of the Punjab Agricultural University, shall be a quorum for a meeting`
  line `of the Board:`
  line
  line `Provided that if a meeting of the Board is adjourned for want of a quorum, no quorum shall be`
  line `necessary at the next meeting for the transaction of the same business.`
  line
  line `(11) The Chancellor shall be the Honorary Chairman of the Board and the Vice-Chancellor, the`
  line `Working Chairman.`
  line
  line `(12) The members of the Board shall not be entitled to receive any remuneration for the performance`
  line `of their functions under this Act except such daily and travelling allowances as may be prescribed:`
  line
  line `Provided that nothing herein shall affect the emoluments or other conditions of service of the`
  line Vice-Chancellor.
  line
  line `(13) On the commencement of this Act, the members of the Board of Management of the existing`
  line `University shall be deemed to have vacated their offices as such.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (30353)
  sectionNo (14)
  orderNo 14
  title `Powers and duties of the Board.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30353&sectionno=14&orderno=14&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_14_content:
  string
  line `The powers and duties of the Board shall be as follows:--`
  line
  line `(a) to approve the budget submitted by the Vice-Chancellor;`
  line
  line `(b) to hold and control the properly and funds of the University and issue any general directive on`
  line `behalf of the University;`
  line
  line `(c) to accept or transfer any property on behalf of the University;`
  line
  line `(d) to administer funds placed at the disposal of the University for specific purposes;`
  line
  line `(e) to invest moneys belonging to the University;`
  line
  line `(f) to appoint the officers, teachers and other employees of the University in the prescribed`
  line manner;
  line
  line `(g) to direct the form and use of the common seal of the University;`
  line
  line `(h) to appoint such committees as it may deem necessary for its proper functioning;`
  line
  line `(i) to borrow money for capital improvements and make suitable arrangements for its repayment;`
  line
  line `(j) to appoint the Vice-Chancellor subject to the provisions of section 15;`
  line
  line `(k) to meet at such times and as often as the Board may deem necessary:`
  line
  line `Provided that regular meetings of the Board shall be held at least once in every two months;`
  line
  line `(l) to regulate and determine all matters concerning the University in accordance with this Act`
  line `and the Statutes, and to exercise such powers and to discharge such duties as may be conferred on or`
  line `imposed upon the Board by this Act or the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (30354)
  sectionNo (15)
  orderNo 15
  title `The Vice-Chancellor.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30354&sectionno=15&orderno=15&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_15_content:
  string
  line `(1) The Vice-Chancellor shall be a whole-time officer of the`
  line `corresponding University and shall be appointed by the Board in the prescribed manner:`
  line
  line `Provided that where the members of the Board are not unanimous with regard to the selection of the`
  line `person proposed to be appointed as the Vice-Chancellor, the appointment shall be made by the Chancellor`
  line `of the concerned corresponding University:`
  line
  line `Provided further that the first Vice-Chancellor of the Haryana Agricultural University shall be`
  line `appointed by the Government of the State of Haryana:`
  line
  line `Provided also that the person holding office immediately before the commencement of this Act as the`
  line `Vice-Chancellor of the existing University shall be deemed to be the first Vice-Chancellor of the Punjab`
  line `Agricultural University and shall hold such office for the unexpired portion of his term of office as the`
  line `Vice-Chancellor of the existing University.`
  line
  line `(2) The term of office of the Vice-Chancellor shall be four years and he shall be eligible for`
  line re-appointment.
  line
  line `(3) The emoluments and other condition; of service of the Vice-Chancellor shall be such as may be`
  line `prescribed and shall not be varied to his disadvantage after his appointment.`
  line
  line `(4) When a vacancy occurs, or is likely to occur, in the office of the Vice-Chancellor by reason of`
  line `leave taken by the Holder of such office or any cause other than the expiry of the term of office, the`
  line `Registrar shall report the fact forthwith to the Board, and such vacancy shall be filled in accordance with`
  line `the provisions of sub-section (1).`
  line
  line `(5) Until the vacancy is filled under sub-section (4) or until such time as the Board designates an`
  line `acting Vice-Chancellor, the senior-most Dean, in the case of the Haryana Agricultural University, or the`
  line `Registrar, in the case of the Punjab Agricultural University, as the case may be, shall carry on the current`
  line `duties of the office of the Vice-Chancellor.`
  line
  line `(6) The Vice-Chancellor may relinquish office by resignation in writing addressed to the Board and`
  line `ordinarily delivered to the Secretary of the Board at least two months prior to the date on which the`
  line `Vice-Chancellor wishes to be relieved.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (30355)
  sectionNo (16)
  orderNo 16
  title `Powers and duties of the Vice-Chancellor.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30355&sectionno=16&orderno=16&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_16_content:
  string
  line `(1) The Vice-Chancellor shall be the principal`
  line `executive and academic officer of the corresponding University and the Chairman of the Academic`
  line `Council and shall, in the absence of the Chancellor, preside at a convocation of the corresponding`
  line `University and shall confer degrees on persons entitled to receive them.`
  line
  line `(2) The Vice-Chancellor shall exercise control over the affairs of the corresponding University and`
  line `shall be responsible for the due maintenance of discipline at that University.`
  line
  line `(3) The Vice-Chancellor shall convene meetings of the Academic Council unless he temporarily`
  line `delegates this power to some other officer of the corresponding University.`
  line
  line `(4) Without prejudice to the powers conferred by this Act on the appropriate Government, the`
  line `Vice-Chancellor shall ensure the faithful observance of the provisions of this Act and the Statutes and he`
  line `shall exercise all such powers as may be necessary in that behalf.`
  line
  line `(5) The Vice-Chancellor shall be responsible for the presentation of the budget and the statement of`
  line `accounts to the Board.`
  line
  line `(6) In any emergency, which, in the opinion of the Vice-Chancellor, requires immediate action to be`
  line `taken, he shall take such action as he deems necessary and shall, at the earliest opportunity, report the`
  line `action taken to the officer, authority or other body for confirmation who or which in the ordinary course`
  line `would have dealt with the matter, but nothing in this sub-section shall be deemed to empower the`
  line `Vice-Chancellor to incur any expenditure not duly authorised and provided for in the budget.`
  line
  line `(7) Where any action by the Vice-Chancellor under sub-section (6) affects any person in the service`
  line `of the corresponding University to his disadvantage, such action shall not be taken unless the person`
  line `concerned has been given a reasonable opportunity of being heard, and the person against whom any`
  line `action is proposed to be taken may prefer an appeal to the Board within thirty days of the date on which`
  line `the action proposed to be taken against him is communicated to him.`
  line
  line `(8) Subject as aforesaid, the Vice-Chancellor shall give effect to the orders of the Board regarding the`
  line `appointment, suspension and dismissal of officers, teachers and other employees of the corresponding`
  line University.
  line
  line `(9) The Vice-Chancellor shall be responsible for the close co-ordination and integration of teaching,`
  line `research and extension education.`
  line
  line `(10) The Vice-Chancellor shall exercise such other powers as may be prescribed.`
  line
  line `(11) The salary and allowances payable to the officers, teachers and other employees of the`
  line `corresponding University shall be determined by the Vice-Chancellor with the approval of the Board.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (30356)
  sectionNo (17)
  orderNo 17
  title `The Registrar.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30356&sectionno=17&orderno=17&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_17_content:
  string
  line `(1) The Registrar of a corresponding University shall be a whole-time office of`
  line `that University and shall be appointed by the Vice-Chancellor of that University with the approval of the`
  line Board.
  line
  line `(2) The Registrar of a corresponding University shall receive such remuneration and other`
  line `emoluments as may be prescribed and shall not, during the tenure of his office, accept any remuneration`
  line `or emolument other than the prescribed remuneration or emolument.`
  line
  line `(3) The powers and duties of the Registrar of a corresponding University shall be as follows:--`
  line
  line `(a) to be responsible for the custody of the records and the common seal of the University;`
  line
  line `(b) to be the ex officio Secretary to the Academic Council and to the Board and to place before`
  line `such Council and Board all such information as may be necessary for the transaction of business of`
  line `the Council or the Board, as the case may be;`
  line
  line `(c) to receive applications for admission into the University;`
  line
  line `(d) to keep a permanent record of all syllabi, curricula and informations connected therewith;`
  line
  line `(e) to make arrangements for the conduct of such examinations as may be prescribed and to be`
  line `responsible for the due execution of all processes connected therewith;`
  line
  line `(f) to perform such other duties as may be prescribed or required, from time to time, by the`
  line Vice-Chancellor.
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (30357)
  sectionNo (18)
  orderNo 18
  title Comptroller.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30357&sectionno=18&orderno=18&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_18_content:
  string
  line `(1) The Comptroller of a corresponding University shall be a whole-time officer`
  line `of that University and shall be appointed by the Vice-Chancellor of that University with the approval of`
  line `the Board.`
  line
  line `(2) The Comptroller shall manage the property and investments of the corresponding University and`
  line `advise it in regard to its financial policy.`
  line
  line `(3) The Comptroller shall be responsible to the Vice-Chancellor for all accounting matters of the`
  line `corresponding University including the preparation and presentation of its Budget and statement of`
  line accounts.
  line
  line `(4) The Comptroller shall receive such remuneration as may be prescribed and shall not, during the`
  line `tenure of his office, receive any remuneration or other emolument other than the prescribed remuneration.`
  line
  line `(5) The Comptroller shall--`
  line
  line `(a) ensure that expenditure, not authorised in the budget, is not incurred by the corresponding`
  line `University except by way of investment; and`
  line
  line `(b) disallow any expenditure not warranted by the terms of any Statute or for which provision is`
  line `required to be made by the Statute but has not been so made.`
  line
  line `(6) All moneys belonging to the corresponding University shall be kept in a Scheduled Bank`
  line `approved by the Board.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (30358)
  sectionNo (19)
  orderNo 19
  title `The Estate Officer.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30358&sectionno=19&orderno=19&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_19_content:
  string
  line `The Estate Officer of a corresponding University, who shall be appointed`
  line `by the Vice-Chancellor with the approval of the Board, shall be responsible for the custody, maintenance`
  line `and management of all the buildings, lawns, gardens and other properties of the University.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (30359)
  sectionNo (20)
  orderNo 20
  title `Director of Student Welfare.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30359&sectionno=20&orderno=20&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_20_content:
  string
  line `(1) The Director of Student Welfare of a corresponding`
  line `University shall be a whole-time officer of that University and shall be appointed by the Vice-Chancellor`
  line `with the approval of the Board.`
  line
  line `(2) The Director of Student Welfare shall have the following duties, namely:--`
  line
  line `(a) to make arrangements for the housing of students;`
  line
  line `(b) to direct a programme of student-counselling;`
  line
  line `(c) to arrange for the employment of students in accordance with the plans approved by the`
  line Vice-Chancellor;
  line
  line `(d) to supervise the extra-curricular activities of students;`
  line
  line `(e) to assist in the placement of graduates of the University; and`
  line
  line `(f) to organise and maintain contact with the Alumni Association of the University.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (30360)
  sectionNo (21)
  orderNo 21
  title `Deans of colleges.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30360&sectionno=21&orderno=21&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_21_content:
  string
  line `(1) Each college shall have a Dean who shall be a whole-time officer and`
  line `shall be appointed by the Vice-Chancellor with the approval of the Board.`
  line
  line `(2) The Dean shall be responsible to the Vice-Chancellor for all matters concerning his college.`
  line
  line `(3) The Dean shall be responsible for the organisation and the conduct of resident instruction of the`
  line `Departments of the college.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (30361)
  sectionNo (22)
  orderNo 22
  title `The Librarian.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30361&sectionno=22&orderno=22&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_22_content:
  string
  line `(1) The Librarian of a corresponding University shall be appointed by the`
  line `Vice-Chancellor with the approval of the Board and shall be in charge of the library.`
  line
  line `(2) The Librarian shall be responsible to the Vice-Chancellor for all matters concerning the library.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (30362)
  sectionNo (23)
  orderNo 23
  title `Academic Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30362&sectionno=23&orderno=23&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_23_content:
  string
  line `(1) The Academic Council shall be in charge of the academic affairs of the`
  line `University and shall, subject to the provisions of this Act and the Statutes, superintend, direct and control,`
  line `and be responsible for the maintenance of standards of instruction, education and examinations and other matters connected with the obtaining of degrees and shall exercise such other powers and perform such`
  line `other duties as may be prescribed.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, the Academic Council shall have`
  line power--
  line
  line `(a) to advise the Vice-Chancellor on all academic matters, including the control and management`
  line `of the libraries;`
  line
  line `(b) to co-opt at its meetings such Heads of Departments as it may consider necessary;`
  line
  line `(c) to make recommendations to the Vice-Chancellor for the institution of the Professorships,`
  line `Associate Professorships, Assistant Professorships and teacherships and other teaching posts and in`
  line `regard to the duties and emoluments thereof;`
  line
  line `(d) to formulate, modify or revise schemes for the constitution or reconstitution of departments of`
  line `teaching, research and extension;`
  line
  line `(e) to make regulations regarding the admission of students to the University;`
  line
  line `(f) to make regulations regarding examinations conducted by the University and the conditions on`
  line `which students shall be admitted to such examinations;`
  line
  line `(g) to make regulations relating to courses of study leading to degrees, diplomas and certificates;`
  line
  line `(h) to make recommendations regarding post-graduate teaching, research and extension;`
  line
  line `(i) to make recommendations regarding the qualifications to be prescribed for teachers in the`
  line University;
  line
  line `(j) to exercise such other powers and perform such other duties as may be conferred or imposed`
  line `on it by or under the provisions of this Act.`
  line
  line `(3) The Academic Council shall consist of--`
  line
  line `(a) the Vice-Chancellor;`
  line
  line `(b) the Deans of the colleges of the University;`
  line
  line `(c) the Dean of Post-Graduate Studies;`
  line
  line `(d) the Director of Extension Education;`
  line
  line `(e) the Director of Research;`
  line
  line `(f) the Head of one Department from each college, to be selected by the respective college.`
  line
  line `(4) The term of office of the members specified in clause (f) of sub-section (3) shall be two years.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (30363)
  sectionNo (24)
  orderNo 24
  title `The colleges.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30363&sectionno=24&orderno=24&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_24_content:
  string
  line `(1) The following colleges shall be the constituent colleges of the Haryana`
  line `Agricultural University, namely:--`
  line
  line `(a) the College of Agriculture at Hissar;`
  line
  line `(b) the College of Veterinary Medicine at Hissar;`
  line
  line `(c) the College of Animal Sciences at Hissar;`
  line
  line `(d) the College of Basic Sciences and the Humanities and such other colleges as may be`
  line `established by the University after the commencement of this Act; and`
  line
  line `(e) such Central Government institutions of agricultural research, technical and extension`
  line `education in the State of Haryana as may desire to be integrated as colleges of the Haryana`
  line `Agricultural University.`
  line
  line `(2) The following colleges shall be the constituent colleges of the Punjab Agricultural University,`
  line `namely:--`
  line
  line `(a) the College of Agriculture at Ludhiana;`
  line
  line `(b) the College of Agricultural Engineering at Ludhiana;`
  line
  line `(c) the College of Basic Sciences and the Humanities at Ludhiana;`
  line
  line `(d) the College of Home Sciences at Ludhiana;`
  line
  line `(e) the College of Veterinary Medicine at Ludhiana;`
  line
  line `(f) until a University is established in the Union territory of Himachal Pradesh, the Agricultural`
  line `College at Palampur;`
  line
  line `(g) such other colleges as may be established by the University after the commencement of this`
  line `Act; and`
  line
  line `(h) such Central Government institutions of agricultural research, technical and extension`
  line `education in the State of Punjab as may desire to be integrated as colleges of the Punjab Agricultural`
  line University.
  line
  line `(3) (a) There shall be a Board of Studies for each college of a corresponding University and where`
  line `there is more than one college in a branch of learning, there may be one Board of Studies for all the`
  line `colleges in that branch of learning.`
  line
  line `(b) The Deans of various colleges shall be the Chairmen of the respective Boards of Studies and the`
  line `Heads of Departments of the colleges shall be members thereof.`
  line
  line `(c) Where there is a Board of Studies for more than one college in a branch of learning, the Deans`
  line `shall act as Chairmen of the Board of Studies by rotation according to seniority for a period of one year`
  line each.
  line
  line `(d) The Vice-Chancellor may nominate to the Board of Studies such other teachers of related subjects`
  line `or sciences from the same or other colleges, as he may deem fit.`
  line
  line `(e) The duties of such Boards of Studies shall be to prescribe syllabi so as to ensure integrated and`
  line `well-balanced courses of study.`
  line
  line `(4) Every college shall comprise such Departments as may be prescribed and each Department shall`
  line `be assigned such subjects of study as the Academic Council may deem fit.`
  line
  line `(5) There shall be a Head of each Department who shall be responsible to the Dean, for resident`
  line `instruction, to the Director of Research, for research, and to the Director of Extension Education, for`
  line `extension education.`
  line
  line `(6) The Head of each Department shall be selected by the Vice-Chancellor and appointed by him with`
  line `the approval of the Board.`
  line
  line `(7) The duties, powers and functions of the Heads of Departments shall be such as may be prescribed.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (30364)
  sectionNo (25)
  orderNo 25
  title `Experiment Stations for research.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30364&sectionno=25&orderno=25&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_25_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes,`
  line `Experiment Stations shall be established under each corresponding University, which shall be responsible`
  line `for research, both fundamental and applied, and research activities shall be concentrated as far as possible`
  line `at the Central Research Stations and other Regional Research and Testing Stations in the different`
  line `agro-climatic zones of the State.`
  line
  line `(2) There shall be a Director of Research in each corresponding University, who shall be responsible`
  line `to the Vice-Chancellor and who shall be appointed by the Vice-Chancellor in consultation with the Deans`
  line `and with the approval of the Board.`
  line
  line `(3) The Director of Research shall be a whole-time officer trained in Agriculture and shall initiate,`
  line `guide and co-ordinate the research programme of the corresponding University and its outlying`
  line sub-stations.
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (30365)
  sectionNo (26)
  orderNo 26
  title `Agricultural Extension Education.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30365&sectionno=26&orderno=26&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_26_content:
  string
  line `(1) In relation to the territories to which the functions of a`
  line `corresponding University extend, such University shall be responsible for--`
  line
  line `(a) the agricultural extension functions which are primarily educational in nature; and`
  line
  line `(b) imparting training to the future Extension Officers for the National Extension Blocks and`
  line `instructors for the Extension Training Centres.`
  line
  line `(2) All Extension Specialists, in relation to any subject-matter, shall be the members of the staff of`
  line `their respective subject-matter sections in each corresponding University and work in close co-ordination`
  line `with the Departments of Agriculture, Development and Co-operatives.`
  line
  line `(3) The Director of Extension Education shall be a whole-time officer technically trained in`
  line `agriculture and shall be appointed by the Vice-Chancellor in consultation with the Deans and with the`
  line `approval of the Board.`
  line
  line `(4) The Director of Extension Education shall be responsible to the Vice-Chancellor and shall`
  line `develop programmes for assisting farmers and housewives in applying results of scientific investigations`
  line `to the solution of their problems.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (30366)
  sectionNo (27)
  orderNo 27
  title `Retirement and other conditions of services.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30366&sectionno=27&orderno=27&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_27_content:
  string
  line `The age of retirement and other conditions of`
  line `service of every officer, teacher or other employee of a corresponding University shall be such as may be`
  line prescribed.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (30367)
  sectionNo (28)
  orderNo 28
  title `Provident fund.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30367&sectionno=28&orderno=28&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_28_content:
  string
  line `Each corresponding University shall constitute gratuity and provident fund for`
  line `the benefit of its officers, teachers and other employees in such manner, and subject to such conditions, as`
  line `may be prescribed.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (30368)
  sectionNo (29)
  orderNo 29
  title `Appointment of salaried officers.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30368&sectionno=29&orderno=29&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_29_content:
  string
  line `Subject to the provisions of this Act, the members of the`
  line `technical staff of a corresponding University shall be selected by the Head of the Department in`
  line `consultation with the members of the Department concerned, recommended by the Dean or the Director`
  line `of Research or the Director of Extension Education, as the case may be, and appointed by the`
  line `Vice-Chancellor with the approval of the Board.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (30369)
  sectionNo (30)
  orderNo 30
  title `Temporary arrangements.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30369&sectionno=30&orderno=30&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_30_content:
  string
  line `The Vice-Chancellor may, until such time as the authorities of the`
  line `corresponding University are duly constituted, temporarily appoint any such officer of that University as`
  line `such University is authorised by this Act to appoint.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (30370)
  sectionNo (31)
  orderNo 31
  title Statutes.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30370&sectionno=31&orderno=31&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_31_content:
  string
  line `Subject to the provisions of this Act, the Statutes of a corresponding University may`
  line `provide for any matter and shall, in particular, provide for the following:--`
  line
  line `(a) the constitution, powers and duties of the authorities of the University;`
  line
  line `(b) the election, appointment, and continuance in office of the members of the authorities of the`
  line `University and of the officers, teachers and other employees of the University including the filling up`
  line `of vacancies and all other matters relating to these authorities and officers, teachers and other`
  line `employees for which it may be necessary or desirable to provide;`
  line
  line `(c) the designation, the manner of appointment, the powers, and the duties of the officers of the`
  line University;
  line
  line `(d) the classification and the manner of appointment of teachers;`
  line
  line `(e) the constitution of gratuity or provident fund or both for the benefit of officers, teachers and`
  line `other employees of the University;`
  line
  line `(f) the institution of degrees and diplomas;`
  line
  line `(g) the conferment of honorary degrees;`
  line
  line `(h) the establishment, amalgamation, sub-division and abolition of Departments;`
  line
  line `(i) the establishment, and the abolition of hostels maintained by the University;`
  line
  line `(j) the institution of fellowships, scholarships, medals and prizes;`
  line
  line `(k) the maintenance of a register of graduates;`
  line
  line `(l) the admission of students to the University and their enrolment and continuance as such;`
  line
  line `(m) the courses of study to be laid down for degrees and diplomas of the University;`
  line
  line `(n) the conditions under which students shall be admitted to the degree, diploma or other courses`
  line `and the manner in which the examinations are to be held and the eligibility for the award of degrees`
  line `and diplomas;`
  line
  line `(o) the conditions of residence of the students of the University and the levy of fees for residence`
  line `in hostels maintained by the University;`
  line
  line `(p) the recognition and supervision of hostels not maintained by the University;`
  line
  line `(q) the number, qualifications, emoluments, and other conditions of service of officers, teachers`
  line `and other employees of the University and the preparation and the maintenance of record of their`
  line `services and activities;`
  line
  line `(r) the fees which may be charged by the University;`
  line
  line `(s) the remuneration and allowances, including travelling and daily allowances, to be paid to`
  line `persons employed on the business of University;`
  line
  line `(t) the conditions for the award of fellowships, scholarships, medals and prizes, stipends and fee`
  line concessions;
  line
  line `(u) all other matters which by this Act are to be or may be provided for by the Statutes.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (30371)
  sectionNo (32)
  orderNo 32
  title `Statutes how made.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30371&sectionno=32&orderno=32&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_32_content:
  string
  line `(1) The Statutes made by the existing University under section 30 of the`
  line `Punjab Agricultural University Act, 1961 (Punjab Act 32 of 1961), and in force immediately before the`
  line `commencement of this Act shall, in so far as they are not inconsistent with the provisions of this Act, and`
  line `subject to such adaptations and modifications as may be notified by the appropriate Government, be the`
  line `first Statutes of a corresponding University.`
  line
  line `(2) The Board may, from time to time, make new or additional Statutes and may amend or repeal the`
  line `Statutes in the manner hereinafter provided in this section.`
  line
  line `(3) The Academic Council may propose to the Board the draft of Statutes and such draft shall be`
  line `considered by the Board at its next meeting:`
  line
  line `Provided that the Academic Council shall not propose the draft of any Statute or any amendment of a`
  line `Statute affecting the status, powers or constitution of any authority of the University until such authority`
  line `has been given an opportunity to express its opinion upon the proposal, and any opinion so expressed`
  line `shall be considered by the Board.`
  line
  line `(4) The Board may consider any such draft as is referred to in sub-section (3) and pass the proposed`
  line `Statute or reject or return it to the Academic Council for re-consideration, either in whole or in part,`
  line `together with any amendment which it may suggest.`
  line
  line `(5) (a) Any member of the Board may propose to the Board the draft of any Statute and the Board`
  line `may either accept or reject the proposal if it relates to a matter not falling within the purview of the`
  line `Academic Council.`
  line
  line `(b) In case such a draft relates to a matter within the purview of the Academic Council, the Board`
  line `shall refer it for consideration to the Academic Council, which may either report to the Board that it does`
  line `not approve the proposal, which, then, shall be deemed to have been rejected by the Board or submit the`
  line `draft to the Board in such form as the Academic Council may approve, and the provisions of this section shall apply in the case of the draft submitted by any member of the Board as they apply in the case of a`
  line `draft presented to the Board by the Academic Council.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (30372)
  sectionNo (33)
  orderNo 33
  title Regulations.
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30372&sectionno=33&orderno=33&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_33_content:
  string
  line `(1) Any authority of a corresponding University may make Regulations consistent`
  line `with this Act and the Statutes for--`
  line
  line `(a) laying down the procedure to be observed at its meetings and the number of members required`
  line `to form a quorum;`
  line
  line `(b) providing for all matters which by this Act and the Statutes are to be provided for by the`
  line `Regulations; and`
  line
  line `(c) providing for any other matter solely concerning the authority and not provided for by this Act`
  line `and the Statutes.`
  line
  line `(2) Every authority of the corresponding University shall make Regulations providing for the giving`
  line `of notice to the members of such authority of the dates of meetings and of the business to be transacted at`
  line `meetings and for keeping of records of the proceedings of the meetings.`
  line
  line `(3) The Academic Council may, subject to the provisions of the Statutes, make Regulations providing`
  line `for courses of study, system of examinations, and degrees and diplomas of a corresponding University`
  line `after receiving drafts of the same from the Board of Studies concerned.`
  line
  line `(4) The Academic Council may not alter a draft received from the Board of Studies, but may reject or`
  line `return it to the Board of Studies for further consideration together with the suggestions of the Academic`
  line Council.
  line
  line `(5) The Board may direct the amendment, in such manner as it may specify, of any Regulation made`
  line `under this section or the annulment of any Regulation made under sub-section (1).`
  line
  line `(6) Notwithstanding anything contained in this section, the Regulations made by the existing`
  line `University under section 31 of the Punjab Agricultural University Act, 1961 (Punjab Act 32 of 1961) and`
  line `in force immediately before the commencement of this Act shall, in so far as they are not inconsistent`
  line `with the provisions of this Act and subject to such adaptations and modifications as may be notified by`
  line `the appropriate Government, be the first Regulations of each corresponding University.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (30373)
  sectionNo (34)
  orderNo 34
  title `Accounts and audit.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30373&sectionno=34&orderno=34&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_34_content:
  string
  line `(1) Each corresponding University shall have a general fund to which`
  line `shall be credited--`
  line
  line `(a) income from fees, endowments and grants and from properties of the University including`
  line `Hostels, Experiment Stations and Farms;`
  line
  line `(b) contributions and grants which may be made by the appropriate Government on such`
  line `conditions which it may impose; and`
  line
  line `(c) other contributions, grants, donations and benefactions.`
  line
  line `(2) Each corresponding University shall constitute a Finance Committee consisting of--`
  line
  line `(a) the Vice-Chancellor;`
  line
  line `(b) the Comptroller;`
  line
  line `(c) a member chosen by the Board from amongst the official members;`
  line
  line `(d) a member chosen by the Board from amongst the non-official members.`
  line
  line `(3) The powers and duties of the Finance Committee of a corresponding University shall be as`
  line follows--
  line
  line `(a) to examine the annual accounts of the University and to advise the Board thereon;`
  line
  line `(b) to examine the annual budget estimates and to advise the Board thereon;`
  line
  line `(c) to review the financial position of the University from time to time;`
  line
  line `(d) to make recommendations to the University on all matters relating to the finances of the`
  line University;
  line
  line `(e) to make recommendations to the Board on all proposals involving expenditure for which no`
  line `provision has been made in the budget or which involves expenditure in excess of the amount`
  line `provided in the budget.`
  line
  line `(4) The accounts and the balance-sheet shall be submitted by the Vice-Chancellor through the Board`
  line `to the appropriate Government which shall cause them to be audited by the Examiner, Local Fund`
  line Accounts.
  line
  line `(5) The accounts, when audited, shall be printed and copies thereof together with audit report, shall be`
  line `submitted by the Vice-Chancellor to the Board, which shall forward them to the appropriate Government`
  line `with such comments as it may deem fit and that Government shall cause a copy of the audited accounts`
  line `together with its comments thereon to be laid before the State Legislature.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (30374)
  sectionNo (35)
  orderNo 35
  title `Division of assets and liabilities.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30374&sectionno=35&orderno=35&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_35_content:
  string
  line `On the commencement of this Act, the assets and liabilities of`
  line `the existing University shall stand transferred to, and shall vest in, the Haryana Agricultural University`
  line `and the Punjab Agricultural University and shall be apportioned between such Universities in accordance`
  line `with the following principles, namely:--`
  line
  line `(a) (i) any asset of the existing University which is, immediately before the commencement of`
  line `this Act, in the State of Haryana, and every right to such property, shall stand transferred to, and shall`
  line `vest in, the Haryana Agricultural University;`
  line
  line `(ii) every other asset and every right thereto shall stand transferred to, and shall vest in, the`
  line `Punjab Agricultural University;`
  line
  line `(b) (i) every liability of the existing University which is relatable to any unit or asset in the State`
  line `of Haryana shall, if subsisting immediately before the commencement of this Act, be the liability of`
  line `the Haryana Agricultural University;`
  line
  line `(ii) every other liability of the existing University, if subsisting on such commencement, shall be`
  line `the liability of the Punjab Agricultural University;`
  line
  line `(c) the cash balances (whether in the form of cash, bank or security deposits) and reserve funds`
  line `held by the existing University, immediately before the commencement of this Act, shall, after`
  line `deducting all the liabilities of the existing University up to such commencement, be apportioned`
  line `between the Haryana Agricultural University and the Punjab Agricultural University in the ratio`
  line `of 40:60;`
  line
  line `(d) every contract made by the existing University before the commencement of this Act shall, if`
  line `subsisting at such commencement, be deemed to have been made--`
  line
  line `(i) in the case of a contract which is relatable to any asset or unit of the existing University in`
  line `the State of Haryana, by the Haryana Agricultural University;`
  line
  line `(ii) in any other case, by the Punjab Agricultural University;`
  line
  line `(e) every share, debenture, bond and other investment made by the existing University shall be`
  line `valued on the basis of average market value thereof during one year immediately before the`
  line `commencement of this Act, and the value so determined shall be apportioned between the Haryana`
  line `Agricultural University and the Punjab Agricultural University in the ratio of 40:60;`
  line
  line `(f) every borrowing made by the existing University before the commencement of this Act shall,`
  line `if the liability is subsisting on such commencement, be repaid together with the interest due thereon`
  line `by the Haryana Agricultural University and the Punjab Agricultural University in the ratio of 40:60;`
  line
  line `(g) the Provident Fund and accruals thereto of every officer or other employee of the existing`
  line `University shall stand transferred to the corresponding University in which he has been posted on the`
  line `date of the commencement of this Act.`
  line
  line `Explanation.--For the purposes of this section, "asset" shall be deemed to include all property,`
  line `movable and immovable, rights, powers, authorities and privileges, and all other rights and interests`
  line `arising out of such property as were immediately before the commencement of this Act in the ownership,`
  line `possession, power or control of the existing University, and all books of accounts, registers, records and`
  line `all other documents of whatever nature relating thereto and shall also be deemed to include all obligations`
  line `of whatever kind then subsisting of the existing University.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (30375)
  sectionNo (36)
  orderNo 36
  title `Legal proceedings.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30375&sectionno=36&orderno=36&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_36_content:
  string
  line `If, at the commencement of this Act, any suit, appeal or other proceeding of`
  line `whatever nature is pending by or against the existing University, the same shall not abate, be discontinued`
  line `or be in any way prejudicially affected by reason of the dissolution of the existing University, but the suit,`
  line `appeal or other proceeding may be continued, prosecuted or enforced by or against--`
  line
  line `(a) the Haryana Agricultural University, if it relates to any property or unit of the existing`
  line `University in the State of Haryana; and`
  line
  line `(b) in any other case, the Punjab Agricultural University.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (30376)
  sectionNo (37)
  orderNo 37
  title `Transfer of employees.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30376&sectionno=37&orderno=37&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_37_content:
  string
  line `(1) Save as otherwise provided in section 13, all officers and other`
  line `employees of the existing University holding office as such immediately before the commencement of`
  line `this Act shall, on such commencement, become the officers or other employees of the corresponding`
  line `University and such officers or other employees shall be divided between those Universities in`
  line `accordance with the following principles, namely:--`
  line
  line `(a) those officers or other employees of the existing University who are holding office in, or in`
  line `connection with, any property or unit of the existing University in the State of Haryana shall become`
  line `the officers or other employees of the Haryana Agricultural University;`
  line
  line `(b) every other officer or other employee of the existing University, shall become the officer or`
  line `other employee of the Punjab Agricultural University.`
  line
  line `(2) Every officer or other employee of the existing University shall, on and from the commencement`
  line `of this Act hold his office or service in the corresponding University on the same terms and conditions`
  line `and with the same rights to pension, provident fund, gratuity and other matters as would have been`
  line `admissible to him if the existing University had not been dissolved, and continue to do so unless and until`
  line `his employment in the corresponding University is duly terminated or until his remuneration and terms or`
  line `conditions of service are duly altered by the corresponding University.`
  line
  line `(3) For the persons who, immediately before the commencement of this Act, were the trustees for`
  line `pension, provident, gratuity or other like fund, constituted for the officers or other employees of the`
  line `existing University, there shall be substituted as trustees such persons as the appropriate Government may`
  line `by general or special order, specify.`
  line
  line `(4) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947), or any`
  line `other law for the time being in force, the transfer of the services of any officer or other employee from the`
  line `existing University to a corresponding University shall not entitle such officer or other employee to any`
  line `compensation, whether under this Act or under any other law for the time being in force, and no such`
  line `claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (30377)
  sectionNo (38)
  orderNo 38
  title `Membership of corresponding University bodies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30377&sectionno=38&orderno=38&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_38_content:
  string
  line `(1) All casual vacancies among the`
  line `members (other than ex officio members) of any authority or body of each corresponding University shall`
  line `be filled, as soon as possible, by the person or body who or which appointed or nominated the member,`
  line `whose place became vacant, and the person appointed or nominated to a casual vacancy shall be a`
  line `member of such authority or body for the remaining period of the term for which the person whose place`
  line `he fills would have been a member.`
  line
  line `(2) A person, who is a member of any authority of a corresponding University as a representative of`
  line `another body, whether of that University or not, shall retain his seat on that authority so long as he`
  line `continues to be a member of the body by which he was appointed or nominated and thereafter till his`
  line `successor is duly appointed or elected.`
  line
  line `(3) No act or proceeding of any authority or body of a corresponding University shall be invalid by`
  line `reason merely of the existence of any vacancy or defect in the constitution of such authority or body.`
  line
  line `(4) If any question arises whether any person has been duly appointed as, or is entitled to be, a`
  line `member of any authority of a corresponding University subordinate to the Board or whether any decision`
  line `of the corresponding University is in accordance with this Act and the Statutes, the question shall be`
  line `referred to the appropriate Government whose decision thereon shall be final.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (30378)
  sectionNo (39)
  orderNo 39
  title `Annual Report.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30378&sectionno=39&orderno=39&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_39_content:
  string
  line `(1) The Annual Report of a corresponding University shall be prepared under`
  line `the directions of the Vice-Chancellor and submitted to the Board at least one month before the annual`
  line `meeting at which it is to be considered.`
  line
  line `(2) The Board shall, after consideration of the Annual Report, forward a copy thereof to the`
  line `appropriate Government.`
  line
  line `(3) On receipt of a copy of the Annual Report referred to in sub-section (1), the appropriate`
  line `Government shall cause a copy of such Report, together with its comments thereon, to be laid before the`
  line `State Legislature.`
  line
  line `(4) Notwithstanding the dissolution of the existing University, the Annual Report of the existing`
  line `University for the year 1969-70 shall be prepared under the directions of the Vice-Chancellor of the`
  line `Punjab Agricultural University and the Board of that University shall, after consideration of the Annual`
  line `Report, forward a copy thereof to the appropriate Government.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (30379)
  sectionNo (40)
  orderNo 40
  title `Construction of references to existing University in any document, etc.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30379&sectionno=40&orderno=40&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_40_content:
  string
  line `Any reference to the`
  line `existing University in any law, other than this Act, or in any contract or other instrument shall be`
  line construed,--
  line
  line `(a) if such reference relates to any asset or property of the existing University in the State of`
  line `Haryana, as a reference to the Haryana Agricultural University; and`
  line
  line `(b) in any other case, as a reference to the Punjab Agricultural University.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (30380)
  sectionNo (41)
  orderNo 41
  title `Obligations to be discharged by the Punjab Agricultural University.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30380&sectionno=41&orderno=41&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_41_content:
  string
  line `Any obligation`
  line `incurred, before the commencement of this Act, by the existing University to confer any degree or other`
  line `academic distinction on, or to issue any diploma or other certificate to, any person or to grant any copy of`
  line `any degree, diploma, certificate, marks-sheet or other document to any person shall, on such`
  line `commencement, be the obligation of the Punjab Agricultural University.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (30381)
  sectionNo (42)
  orderNo 42
  title `Proportion of cost to be borne by the Government of Himachal Pradesh.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30381&sectionno=42&orderno=42&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_42_content:
  string
  line `In consideration of`
  line `the maintenance, by the Punjab Agricultural University, of a campus at Palampur, the Government of the`
  line `Union territory of Himachal Pradesh shall bear a portion of the cost of the Punjab Agricultural University`
  line `and the quantum of such cost shall be determined by the Central Government having regard to the benefit`
  line `derived by that Union territory.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (30382)
  sectionNo (43)
  orderNo 43
  title `Settlement of unresolved disputes.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30382&sectionno=43&orderno=43&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_43_content:
  string
  line `(1) If any dispute arises by reason of the dissolution of the`
  line `existing University, such dispute shall be resolved in the first instance by the Vice-Chancellors of the`
  line `corresponding Universities and in the event of the failure of such Vice-Chancellors to arrive at an agreed`
  line `solution with regard to any such dispute, the matter shall be referred to the Secretary to the Government`
  line `of India in the Ministry dealing with Agriculture and the decision thereon of such Secretary shall be final.`
  line
  line `(2) If, on the establishment of a University in the Union territory of Himachal Pradesh, any dispute`
  line `arises with regard to the transfer of assets or liabilities pertaining to the Agricultural College at Palampur`
  line `or the research, training and extension centres, or property, of the Punjab Agricultural University located`
  line `in the said Union territory or with regard to the transfer of the officers or other employees of such College`
  line `or centres to the University established in the Union territory of Himachal Pradesh, such dispute shall be`
  line `resolved in the first instance by the Vice-Chancellor of the Punjab Agricultural University and the Chief Secretary to the Government of the Union territory of Himachal Pradesh and in the event of their`
  line `failure to arrive at an agreed solution with regard to any such dispute, the matter shall be referred to the`
  line `Secretary to the Government of India in the Ministry dealing with Agriculture and the decision thereon of`
  line `such Secretary shall be final.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (30383)
  sectionNo (44)
  orderNo 44
  title `Power to remove difficulties.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30383&sectionno=44&orderno=44&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_44_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the President may, by order, do anything, not inconsistent with such provisions, which appears to`
  line `him to be necessary or expedient for the purpose of removing the difficulty:`
  line
  line `Provided that no such power shall be exercised after the expiry of the period of two years from the`
  line `commencement of this Act.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (30384)
  sectionNo (45)
  orderNo 45
  title `Repeals and saving.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00003_197016_1517807321470&sectionId=30384&sectionno=45&orderno=45&orgactid=AC_CEN_23_47_00003_197016_1517807321470
obj_root_law_sections_45_content:
  string
  line `(1) The Punjab Agricultural University Act, 1961 (Punjab`
  line `Act 32 of 1961), is hereby repealed.`
  line
  line `(2) The provisions of the General Clauses Act, 1897 (10 of 1897), shall apply to the repeal of the said`
  line `Act as if the said Act were a Central Act.`
  line
  line `(3) The Haryana and Punjab Agricultural Universities Ordinance, 1970 (1 of 1970), is hereby`
  line repealed.
  line
  line `(4) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_45_footnotes:
  string
  line
