  line `14. Chamar, Mochi, Muchi, Chamar - Ravidas, Chamar - Rohidas`
  line `15. Chambhar`
  line `16. Chandala`
  line `17. Dakkal, Dokkalwar`
  line `18. Dandasi`
  line `19. Dhor`
  line `20. Dom, Dombara, Paidi, Pano`
  line `21. Ellamalawar, Yellammalawandlu`
  line `22. Ghasi, Haddi, Relli, Chanchandi`
  line `23. Godari`
  line `24. Gosangi`
  line `25. Holeya`
  line `26. Holeya Dasari`
  line `27. Jaggali`
  line `28. Jambuvulu`
  line `29. Kolupulvandlu, Pambada, Pambanda, Pambala`
  line `30. Madasi Kuruva, Madari Kuruva`
