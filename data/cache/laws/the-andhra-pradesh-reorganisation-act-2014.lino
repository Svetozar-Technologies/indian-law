obj_root_law_translations_hi_sections_50_content:
  string
  line 45
  line `30. मदािस, कु ᱧ वा, मदारी कु ᱧ वा`
  line `31. मा ᳰ दगा`
  line `32. मा ᳰ दगा दासु, माटीन`
  line `33. महार`
  line `34. माला, माला आयावा ᱧ`
  line `35. माला दास ᳯ र`
  line `36. माला दासु`
  line `37. माला ह ᭠ नाइ`
  line `38. माला जंगम`
  line `39. माल मि ᭭ त`
  line `40. माला साले, ने ᭗ कािन`
  line `41. माला स ᭠ यासी`
  line `42. मांग`
  line `43. मांग गारोडी`
  line `44. म ᭠ न`
  line `45. मि ᭬ ट`
  line `46. मातंिग`
  line `47. मेहतर`
  line `48. िमता अ ᭦ य ᭨ वार`
  line `49. मुडला`
  line `50. पा ᳰ क, मो ᳯ ट, तो ᳯ ट`
  line `51. पािमडी`
  line `52. पंचम पे ᳯ रया`
  line `53. रेि ᭨ ल`
  line `54. सामगार`
  line `55. स ᭥ बन`
  line `56. स ᮧ ु`
  line `57. ᳲ सधो ᭨ लु, ᳲ चदो ᭨ लु`
  line `58. यातला`
  line `59. व ᭨ लूवन। ”।`
