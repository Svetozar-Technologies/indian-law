obj_root_laws_copyright_act_1957_sections_1:
  object
  (str sectionId) (str 14503)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, extent and commencement`)
  (str content) (str `(1) This Act may be called the Copyright Act, 1957.

(2) It extends to the whole of India.

(3) It shall come into force on such date as the Central Government may, by notification in the Official Gazette, appoint.`)
  (str footnotes) (str `1. 21st January, 1958, vide notification No. 269, dated 21st January 1958, see Gazette of India, Extraordinary, Part II, sec. 3.`)
obj_root_laws_copyright_act_1957_sections_2:
  object
  (str sectionId) (str 14504)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Interpretation)
  (str content) (str `In this Act, unless the context otherwise requires, selected definitions include adapted work, author, broadcast, cinematograph film, communication to the public, computer programme, copyright society, dramatic work, engraving, Government work, Indian work, literary work, musical work, performance, performer, photograph, plate, prescribed, public library, Registrar of Copyrights, reprography, sound recording and work of joint authorship.`)
  (str footnotes) (str `Prototype excerpt. The refresh workflow fetches the full current section text from India Code.`)
obj_root_laws_copyright_act_1957_sections_3:
  object
  (str sectionId) (str 14505)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Meaning of publication`)
  (str content) (str `For the purposes of this Act, publication means making a work available to the public by issue of copies or by communicating the work to the public.`)
  (str footnotes) (str `Prototype excerpt. The refresh workflow fetches the full current section text from India Code.`)
