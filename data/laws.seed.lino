obj_root_laws_copyright_act_1957_sections_1:
  sectionId (14503)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement`
  content obj_root_laws_copyright_act_1957_sections_1_content
  footnotes `1. 21st January, 1958, vide notification No. 269, dated 21st January 1958, see Gazette of India, Extraordinary, Part II, sec. 3.`
obj_root_laws_copyright_act_1957_sections_1_content:
  string
  line `(1) This Act may be called the Copyright Act, 1957.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date as the Central Government may, by notification in the Official Gazette, appoint.`
obj_root_laws_copyright_act_1957_sections_2:
  sectionId (14504)
  sectionNo (2)
  orderNo 2
  title Interpretation
  content `In this Act, unless the context otherwise requires, selected definitions include adapted work, author, broadcast, cinematograph film, communication to the public, computer programme, copyright society, dramatic work, engraving, Government work, Indian work, literary work, musical work, performance, performer, photograph, plate, prescribed, public library, Registrar of Copyrights, reprography, sound recording and work of joint authorship.`
  footnotes `Prototype excerpt. The refresh workflow fetches the full current section text from India Code.`
obj_root_laws_copyright_act_1957_sections_3:
  sectionId (14505)
  sectionNo (3)
  orderNo 3
  title `Meaning of publication`
  content `For the purposes of this Act, publication means making a work available to the public by issue of copies or by communicating the work to the public.`
  footnotes `Prototype excerpt. The refresh workflow fetches the full current section text from India Code.`
