  code: 'ERR_ASSERTION'
  name: 'AssertionError'
  expected:
  actual: |-
    name: Refresh Laws and Deploy Pages

    on:
      push:
        branches:
          - main
      schedule:
        - cron: "17 2 * * 1"
      workflow_dispatch:
        inputs:
          fetch_limit:
            description: "Maximum laws to fetch. Use 0 for the full discovered list."
            required: false
            default: "0"
          max_sections:
            description: "Maximum sections per law for diagnostics. Leave empty for all sections."
            required: false
            default: ""
          regional_pages:
            description: "Regional-language listing pages to inspect per language."
            required: false
            default: "10"
          checkpoint_minutes:
            description: "Minutes to fetch before committing partial progress."
            required: false
            default: "55"
          max_chunks:
            description: "Maximum checkpoint chunks to run in one workflow execution."
            required: false
            default: "1"

    permissions:
      contents: write
      pages: write
      id-token: write

    concurrency:
      group: pages-refresh
      cancel-in-progress: false

    jobs:
      refresh:
        name: Refresh Official Sources
        runs-on: ubuntu-latest
        timeout-minutes: 75
        environment:
          name: github-pages
          url: ${{ steps.deployment.outputs.page_url }}
        steps:
          - name: Checkout
            uses: actions/checkout@v6
            with:
              ref: main

          - name: Setup Node
            uses: actions/setup-node@v6
            with:
              node-version: 20
              cache: npm

          - name: Install
            run: npm ci

          - name: Discover Central Acts
            env:
              FETCH_LIMIT: ${{ github.event.inputs.fetch_limit || '0' }}
            run: node scripts/discover-laws.mjs --limit "$FETCH_LIMIT" --output data/laws.discovered.lino --delay-ms 1100

          - name: Discover Regional Language Sources
            env:
              REGIONAL_PAGES: ${{ github.event.inputs.regional_pages || '10' }}
            run: node scripts/discover-regional-sources.mjs --max-pages "$REGIONAL_PAGES" --output data/regional-sources.discovered.lino --delay-ms 1100

          - name: Configure commit author
            run: |
              git config user.name "github-actions[bot]"
              git config user.email "41898282+github-actions[bot]@users.noreply.github.com"

          - name: Build Pages with resumable checkpoints
            env:
              MAX_SECTIONS: ${{ github.event.inputs.max_sections }}
              CHECKPOINT_MINUTES: ${{ github.event.inputs.checkpoint_minutes || '55' }}
              MAX_CHUNKS: ${{ github.event.inputs.max_chunks || '1' }}
            run: |
              set -euxo pipefail

              echo "Starting resumable refresh with CHECKPOINT_MINUTES=$CHECKPOINT_MINUTES, MAX_CHUNKS=$MAX_CHUNKS, MAX_SECTIONS=${MAX_SECTIONS:-all}."

              commit_generated() {
                local message="$1"
                echo "Staging generated docs and cache for commit: $message"
                echo "Workspace status before staging generated files:"
                git status --short
                git add docs
                git add -f data/laws.discovered.lino data/regional-sources.discovered.lino
                if [ -d data/cache ]; then
                  echo "Staging data/cache"
                  git add data/cache
                else
                  echo "No data/cache directory exists yet."
                fi
                echo "Workspace status after staging generated files:"
                git status --short
                echo "Staged generated change summary:"
                git diff --cached --stat
                if git diff --cached --quiet; then
                  echo "No generated docs or cache changes to commit."
                  return
                fi
                git commit -m "$message"
                echo "Created checkpoint commit $(git rev-parse --short HEAD)."
                git push origin HEAD:main
                echo "Pushed checkpoint commit $(git rev-parse --short HEAD) to main."
              }

              sync_commit_message() {
                local chunk="$1"
                local max_chunks="$2"
                if [ "$max_chunks" -eq 1 ]; then
                  echo "Laws sync"
                else
                  echo "Laws sync chunk $chunk of $max_chunks"
                fi
              }

              checkpoint_ms=$(( CHECKPOINT_MINUTES * 60 * 1000 ))
              echo "Computed checkpoint runtime budget: $checkpoint_ms ms."
              args=(
                --fetch
                --manifest data/laws.discovered.lino
                --regional-sources data/regional-sources.discovered.lino
                --delay-ms 1100
                --cache-dir data/cache/laws
                --cache-ttl-days 30
                --progress-file data/cache/refresh-status.lino
                --max-runtime-ms "$checkpoint_ms"
                --progress-interval-ms 30000
              )
              if [ -n "$MAX_SECTIONS" ]; then
                echo "Limiting section fetches to MAX_SECTIONS=$MAX_SECTIONS."
                args+=(--max-sections "$MAX_SECTIONS")
              else
                echo "Fetching all sections for each law."
              fi
              printf 'Build arguments: %q\n' "${args[@]}"

              status=75
              for chunk in $(seq 1 "$MAX_CHUNKS"); do
                echo "::group::Refresh chunk $chunk of $MAX_CHUNKS"
                set +e
                node scripts/build-site.mjs "${args[@]}"
                status=$?
                set -e
                echo "::endgroup::"

                commit_generated "$(sync_commit_message "$chunk" "$MAX_CHUNKS")"

                if [ "$status" -eq 0 ]; then
                  echo "Refresh completed."
                  break
                fi
                if [ "$status" -ne 75 ]; then
                  echo "::error::Refresh failed with exit code $status."
                  exit "$status"
                fi
                echo "Checkpoint reached; continuing from committed cached laws."
                if [ "$chunk" -eq "$MAX_CHUNKS" ]; then
                  echo "::notice::Refresh checkpoint saved after $MAX_CHUNKS chunk(s); run this workflow again to continue."
                fi
              done

          - name: Configure GitHub Pages
            uses: actions/configure-pages@v6

          - name: Upload GitHub Pages artifact
            uses: actions/upload-pages-artifact@v5
            with:
              path: docs

          - name: Deploy to GitHub Pages
            id: deployment
            uses: actions/deploy-pages@v5

  operator: 'match'
